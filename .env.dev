# =============================================================================
# Value Fabric — Local Development Environment Variables
# =============================================================================
# Copy to .env or pass via docker compose --env-file .env.dev
#
# These are SAFE DEFAULTS for local exploration. No real secrets.
# =============================================================================

# Auth bypass — auto-authenticates every request as a dev tenant
DEV_AUTH_BYPASS=true

# JWT secret — required by jwt.py at import time (not used when bypass is active)
JWT_SECRET=dev-local-secret-do-not-use-in-production-minimum-32-chars

# LLM keys — optional. Leave blank for heuristic-only mode.
# Set your real keys here if you want C1/LLM responses.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
THESYS_API_KEY=

# LLM model selection
LLM_MODEL=gpt-4o

# Neo4j
NEO4J_PASSWORD=devpassword

# Redis (no password in dev)
REDIS_PASSWORD=

# Logging
LOG_LEVEL=debug
