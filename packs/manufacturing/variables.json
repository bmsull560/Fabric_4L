{
  "pack_id": "manufacturing-v1",
  "variables": [
    {
      "variable_id": "mfg-var-001",
      "variable_name": "Current_OEE",
      "display_name": "Current OEE Percentage",
      "description": "Current Overall Equipment Effectiveness as a percentage. Combines availability, performance, and quality metrics.",
      "data_type": "PERCENTAGE",
      "unit_of_measure": "%",
      "valid_range": {
        "min": 0,
        "max": 100
      },
      "default_value": 75.0,
      "source_type": "DERIVED",
      "derivation": {
        "formula": "(Availability * Performance * Quality) / 10000",
        "components": [
          "Availability",
          "Performance",
          "Quality_Rate"
        ]
      },
      "source_binding": {
        "system": "MES",
        "entity": "ProductionLine",
        "attribute": "oee_percentage",
        "refresh_frequency": "realtime"
      },
      "validation_rules": [
        {
          "type": "range",
          "min": 0,
          "max": 100,
          "error_message": "OEE must be between 0% and 100%"
        },
        {
          "type": "trend",
          "max_change_percent": 50,
          "window": "1h",
          "error_message": "OEE change exceeds normal variance"
        }
      ],
      "tags": [
        "oee",
        "efficiency",
        "kpi",
        "realtime"
      ],
      "industry_benchmarks": {
        "world_class": 85,
        "average": 60,
        "poor": 40
      },
      "used_in_formulas": [
        "mfg-f-001"
      ],
      "canonicalName": "Current_OEE",
      "name": "Current OEE Percentage"
    },
    {
      "variable_id": "mfg-var-002",
      "variable_name": "Availability",
      "display_name": "Equipment Availability",
      "description": "Percentage of scheduled time that equipment is available for production",
      "data_type": "PERCENTAGE",
      "unit_of_measure": "%",
      "valid_range": {
        "min": 0,
        "max": 100
      },
      "default_value": 90.0,
      "source_type": "DERIVED",
      "derivation": {
        "formula": "(Planned_Production_Time - Downtime) / Planned_Production_Time * 100"
      },
      "source_binding": {
        "system": "MES",
        "entity": "Equipment",
        "attribute": "availability_percent",
        "refresh_frequency": "realtime"
      },
      "validation_rules": [
        {
          "type": "range",
          "min": 0,
          "max": 100
        }
      ],
      "tags": [
        "availability",
        "uptime",
        "downtime"
      ],
      "used_in_formulas": [
        "mfg-f-001"
      ],
      "canonicalName": "Availability",
      "name": "Equipment Availability"
    },
    {
      "variable_id": "mfg-var-003",
      "variable_name": "Performance",
