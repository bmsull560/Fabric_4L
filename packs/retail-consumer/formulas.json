{
  "pack_id": "retail-consumer-v1",
  "formulas": [
    {
      "formula_id": "rc-f-001",
      "name": "Omnichannel Fulfillment ROI",
      "description": "Return on investment from omnichannel fulfillment capabilities including ship-from-store, buy-online-pickup-in-store (BOPIS), and same-day delivery optimization.",
      "formula_type": "ROI",
      "version": "1.0.0",
      "status": "active",
      "governance": {
        "owner": "Omnichannel Value Engineering",
        "review_cycle": "quarterly",
        "approval_status": "approved",
        "last_reviewed": "2026-04-15",
        "validated_by": "Supply Chain CoE"
      },
      "expression": {
        "format": "STRING_EXPRESSION",
        "string": "(Incremental_Revenue + Cost_Avoidance - Fulfillment_Cost_Inflation) / Omnichannel_Investment * 100",
        "variables": [
          "Incremental_Revenue",
          "Cost_Avoidance",
          "Fulfillment_Cost_Inflation",
          "Omnichannel_Investment"
        ]
      },
      "unit_of_result": "%",
      "precision": 1,
      "valid_range": {
        "min": -30,
        "max": 500
      },
      "required_variables": [
        {
          "name": "Incremental_Revenue",
          "display_name": "Incremental Revenue from Omnichannel",
          "type": "currency",
          "unit": "USD",
          "valid_range": { "min": 0, "max": 1000000000 },
          "default_value": 50000000,
          "source": "Sales_Analytics",
          "description": "Additional revenue from omnichannel customers and basket size increase"
        },
        {
          "name": "Cost_Avoidance",
          "display_name": "Fulfillment Cost Avoidance",
          "type": "currency",
          "unit": "USD",
          "valid_range": { "min": 0, "max": 100000000 },
          "default_value": 15000000,
          "source": "Supply_Chain",
          "description": "Savings from store-based fulfillment vs distribution center"
        },
        {
          "name": "Fulfillment_Cost_Inflation",
          "display_name": "Fulfillment Cost Inflation",
          "type": "currency",
          "unit": "USD",
          "valid_range": { "min": 0, "max": 100000000 },
          "default_value": 20000000,
          "source": "Supply_Chain",
          "description": "Additional costs from same-day and expedited fulfillment"
        },
        {
          "name": "Omnichannel_Investment",
          "display_name": "Omnichannel Platform Investment",
          "type": "currency",
          "unit": "USD",
          "valid_range": { "min": 0, "max": 200000000 },
          "default_value": 30000000,
          "source": "Financial",
          "description": "Annual investment in OMS, inventory visibility, and store fulfillment"
        }
      ],
      "benchmarks": {
        "omni_customer_value_lift": 30,
        "bopis_adoption": 25
      },
      "tags": ["omnichannel", "fulfillment", "bopis", "ship-from-store", "roi"]
    },
