{
  "pack_id": "life-sciences-v1",
  "formulas": [
    {
      "formula_id": "ls-f-001",
      "name": "Clinical Trial Acceleration Value",
      "description": "Net present value of accelerating clinical trial timelines. Each month of acceleration brings forward revenue streams and extends effective patent life. Value accounts for time-value of money and competitive positioning.",
      "formula_type": "NPV",
      "version": "1.0.0",
      "status": "active",
      "governance": {
        "owner": "Life Sciences Value Engineering",
        "review_cycle": "quarterly",
        "approval_status": "approved",
        "last_reviewed": "2026-04-11",
        "validated_by": "Clinical Development CoE"
      },
      "expression": {
        "format": "STRING_EXPRESSION",
        "string": "(Current_Timeline_Months - Target_Timeline_Months) / 12 * Peak_Annual_Revenue * NPV_Discount_Factor - Acceleration_Program_Cost",
        "variables": [
          "Current_Timeline_Months",
          "Target_Timeline_Months",
          "Peak_Annual_Revenue",
          "NPV_Discount_Factor",
          "Acceleration_Program_Cost"
        ]
      },
      "unit_of_result": "USD",
      "precision": 0,
      "valid_range": {
        "min": -50000000,
        "max": 1000000000
      },
      "required_variables": [
        {
          "name": "Current_Timeline_Months",
          "display_name": "Current Development Timeline",
          "type": "integer",
          "unit": "months",
          "valid_range": { "min": 24, "max": 180 },
          "default_value": 72,
          "source": "Clinical_Planning",
          "description": "Current estimated months from IND to market"
        },
        {
          "name": "Target_Timeline_Months",
          "display_name": "Target Development Timeline",
          "type": "integer",
          "unit": "months",
          "valid_range": { "min": 24, "max": 180 },
          "default_value": 60,
          "source": "Clinical_Planning",
          "description": "Target months with acceleration initiatives"
        },
        {
          "name": "Peak_Annual_Revenue",
          "display_name": "Peak Annual Revenue Forecast",
          "type": "currency",
          "unit": "USD",
          "valid_range": { "min": 0, "max": 10000000000 },
          "source": "Commercial_Forecasting",
          "description": "Forecasted peak annual revenue at maturity"
        },
        {
          "name": "NPV_Discount_Factor",
          "display_name": "NPV Discount Factor",
          "type": "rate",
          "unit": "ratio",
          "valid_range": { "min": 0.1, "max": 1.0 },
          "default_value": 0.85,
          "source": "Financial",
          "description": "Net present value factor for time acceleration"
        },
        {
          "name": "Acceleration_Program_Cost",
          "display_name": "Timeline Acceleration Program Cost",
          "type": "currency",
          "unit": "USD",
          "valid_range": { "min": 0, "max": 100000000 },
          "default_value": 10000000,
          "source": "Financial",
          "description": "Annual investment in DCT, adaptive design, site optimization"
        }
      ],
      "benchmarks": {
        "typical_months_saved": 12,
        "fast_development": 48,
        "average_development": 72
      },
      "tags": ["time-to-market", "clinical-trials", "npv", "acceleration"]
    },
    {
      "formula_id": "ls-f-002",
      "name": "Patient Recruitment Efficiency",
      "description": "Value created by reducing patient recruitment costs through digital recruitment, site optimization, and retention programs. Includes direct cost savings and indirect benefits from faster enrollment.",
      "formula_type": "CUSTOM",
      "version": "1.0.0",
      "status": "active",
