        {
          "name": "Required_Patients",
          "display_name": "Total Required Patient Enrollment",
          "type": "integer",
          "unit": "patients",
          "valid_range": { "min": 10, "max": 100000 },
          "source": "Clinical_Protocol",
          "description": "Total patients needed across all trials"
        },
        {
          "name": "Digital_Recruitment_Investment",
          "display_name": "Digital Recruitment Investment",
          "type": "currency",
          "unit": "USD",
          "valid_range": { "min": 0, "max": 20000000 },
          "default_value": 2000000,
