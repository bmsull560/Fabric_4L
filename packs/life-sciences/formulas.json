          "Target_Cost_Per_Patient",
          "Required_Patients",
          "Digital_Recruitment_Investment"
        ]
      },
      "unit_of_result": "USD",
      "precision": 0,
      "valid_range": {
        "min": -10000000,
        "max": 50000000
