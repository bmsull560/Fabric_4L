          "unit": "%",
          "valid_range": { "min": 5, "max": 50 },
          "default_value": 15,
          "source": "Portfolio_Analytics",
          "description": "Current probability of technical and regulatory success"
        },
        {
          "name": "Improved_Success_Rate",
          "display_name": "Improved Probability of Success",
          "type": "rate",
          "unit": "%",
          "valid_range": { "min": 5, "max": 60 },
          "default_value": 22,
          "source": "Portfolio_Analytics",
          "description": "Target probability with enhanced decision-making"
        },
        {
          "name": "Pipeline_Risk_Adjusted_NPV",
          "display_name": "Pipeline Risk-Adjusted NPV",
          "type": "currency",
          "unit": "USD",
          "valid_range": { "min": 0, "max": 100000000000 },
          "source": "Portfolio_Analytics",
          "description": "Total risk-adjusted NPV of R&D pipeline"
        },
        {
          "name": "Additional_R&D_Investment",
          "display_name": "Additional R&D Investment",
          "type": "currency",
          "unit": "USD",
          "valid_range": { "min": 0, "max": 500000000 },
          "default_value": 50000000,
          "source": "Financial",
          "description": "Incremental investment in R&D capabilities and analytics"
        }
      ],
      "benchmarks": {
        "industry_avg_pos": 15,
        "best_in_class_pos": 30
      },
      "tags": ["rd-portfolio", "probability-of-success", "npv", "roi"]
    },
