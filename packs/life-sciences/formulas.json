      "required_variables": [
        {
          "name": "Current_Cost_Per_Patient",
          "display_name": "Current Recruitment Cost Per Patient",
          "type": "currency",
          "unit": "USD",
          "valid_range": { "min": 0, "max": 100000 },
          "default_value": 35000,
          "source": "Clinical_Operations",
          "description": "Fully-loaded cost per enrolled patient"
        },
        {
          "name": "Target_Cost_Per_Patient",
          "display_name": "Target Recruitment Cost Per Patient",
          "type": "currency",
          "unit": "USD",
          "valid_range": { "min": 0, "max": 100000 },
          "default_value": 25000,
          "source": "Clinical_Operations",
          "description": "Target cost with digital recruitment optimization"
