        "review_cycle": "quarterly",
        "approval_status": "approved",
        "last_reviewed": "2026-04-11"
      },
      "expression": {
        "format": "STRING_EXPRESSION",
        "string": "(Current_Cost_Per_Patient - Target_Cost_Per_Patient) * Required_Patients - Digital_Recruitment_Investment",
