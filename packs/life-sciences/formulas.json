          "description": "Investment in DCT, patient platforms, digital advertising"
        }
      ],
      "benchmarks": {
        "typical_recruitment_cost": 30000,
        "optimized_recruitment_cost": 20000
      },
      "tags": ["patient-recruitment", "dct", "cost-reduction", "enrollment"]
    },
    {
      "formula_id": "ls-f-003",
      "name": "R&D Portfolio ROI",
      "description": "Return on investment from R&D efficiency improvements that increase probability of technical and regulatory success. Value includes higher NPV from improved success rates and optimized resource allocation.",
      "formula_type": "ROI",
      "version": "1.0.0",
      "status": "active",
      "governance": {
        "owner": "R&D Value Engineering",
        "review_cycle": "quarterly",
        "approval_status": "approved",
        "last_reviewed": "2026-04-11"
      },
      "expression": {
        "format": "STRING_EXPRESSION",
        "string": "(Improved_Success_Rate - Baseline_Success_Rate) / 100 * Pipeline_Risk_Adjusted_NPV / Additional_R&D_Investment * 100",
        "variables": [
          "Improved_Success_Rate",
          "Baseline_Success_Rate",
          "Pipeline_Risk_Adjusted_NPV",
