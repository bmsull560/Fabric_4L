{
  "pack_id": "ai-technology-v1",
  "formulas": [
    {
      "formula_id": "ai-f-001",
      "name": "AI Model Operationalization ROI",
      "description": "Return on investment from operationalizing AI models including inference cost optimization, reduced model drift, automated retraining, and faster time-to-production.",
      "formula_type": "ROI",
      "version": "1.0.0",
      "status": "active",
      "governance": {
        "owner": "AI Platform Value Engineering",
        "review_cycle": "quarterly",
        "approval_status": "approved",
        "last_reviewed": "2026-04-15",
        "validated_by": "MLOps CoE"
      },
      "expression": {
        "format": "STRING_EXPRESSION",
        "string": "(Inference_Cost_Savings + Drift_Reduction_Value + Velocity_Value - MLOps_Investment) / MLOps_Investment * 100",
        "variables": [
          "Inference_Cost_Savings",
          "Drift_Reduction_Value",
          "Velocity_Value",
          "MLOps_Investment"
        ]
      },
      "unit_of_result": "%",
      "precision": 1,
      "valid_range": {
        "min": -50,
        "max": 1000
      },
      "required_variables": [
        {
          "name": "Inference_Cost_Savings",
          "display_name": "Annual Inference Cost Savings",
          "type": "currency",
          "unit": "USD",
          "valid_range": { "min": 0, "max": 100000000 },
          "default_value": 5000000,
          "source": "Cloud_Billing",
          "description": "Savings from model compression, quantization, and optimized serving"
        },
        {
          "name": "Drift_Reduction_Value",
          "display_name": "Model Drift Reduction Value",
          "type": "currency",
          "unit": "USD",
          "valid_range": { "min": 0, "max": 50000000 },
          "default_value": 8000000,
          "source": "ML_Operations",
          "description": "Value from reduced performance degradation through automated monitoring"
        },
        {
          "name": "Velocity_Value",
          "display_name": "Time-to-Production Value",
          "type": "currency",
          "unit": "USD",
          "valid_range": { "min": 0, "max": 50000000 },
          "default_value": 12000000,
          "source": "Product",
          "description": "Value from faster model deployment and revenue acceleration"
        },
        {
          "name": "MLOps_Investment",
          "display_name": "MLOps Platform Investment",
          "type": "currency",
          "unit": "USD",
          "valid_range": { "min": 0, "max": 50000000 },
          "default_value": 8000000,
          "source": "Financial",
          "description": "Annual investment in ML platform, tools, and infrastructure"
        }
      ],
      "benchmarks": {
        "typical_mlops_roi": 300,
        "model_velocity_weeks": 4
      },
      "tags": ["mlops", "ai-operationalization", "model-serving", "roi"]
    },
