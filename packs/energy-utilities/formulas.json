{
  "pack_id": "energy-utilities-v1",
  "formulas": [
    {
      "formula_id": "eu-f-001",
      "name": "Grid Modernization ROI",
      "description": "Return on investment from smart grid infrastructure including reduced outage duration, operational efficiency, and deferred capital expenditure on traditional infrastructure.",
      "formula_type": "ROI",
      "version": "1.0.0",
      "status": "active",
      "governance": {
        "owner": "Grid Operations Value Engineering",
        "review_cycle": "annual",
        "approval_status": "approved",
        "last_reviewed": "2026-04-15",
        "validated_by": "Grid Planning CoE"
      },
      "expression": {
        "format": "STRING_EXPRESSION",
        "string": "(Outage_Cost_Savings + Operational_Savings + Deferred_Capex_Value - Annual_Smart_Grid_Cost) / Cumulative_Investment * 100",
        "variables": [
          "Outage_Cost_Savings",
          "Operational_Savings",
          "Deferred_Capex_Value",
          "Annual_Smart_Grid_Cost",
          "Cumulative_Investment"
        ]
      },
      "unit_of_result": "%",
      "precision": 1,
      "valid_range": {
        "min": -20,
        "max": 300
      },
      "required_variables": [
        {
          "name": "Outage_Cost_Savings",
          "display_name": "Annual Outage Cost Savings",
          "type": "currency",
          "unit": "USD",
          "valid_range": { "min": 0, "max": 500000000 },
          "source": "Operations",
          "description": "Savings from reduced SAIDI/SAIFI and faster restoration"
        },
        {
          "name": "Operational_Savings",
          "display_name": "Annual Operational Savings",
          "type": "currency",
          "unit": "USD",
          "valid_range": { "min": 0, "max": 100000000 },
          "default_value": 15000000,
          "source": "Operations",
          "description": "Savings from automated switching, remote monitoring, reduced truck rolls"
        },
        {
          "name": "Deferred_Capex_Value",
          "display_name": "Deferred Capital Expenditure Value",
          "type": "currency",
          "unit": "USD",
          "valid_range": { "min": 0, "max": 500000000 },
          "default_value": 50000000,
          "source": "Planning",
          "description": "Value from deferring traditional infrastructure investments"
        },
        {
          "name": "Annual_Smart_Grid_Cost",
          "display_name": "Annual Smart Grid Operating Cost",
          "type": "currency",
          "unit": "USD",
          "valid_range": { "min": 0, "max": 100000000 },
          "default_value": 20000000,
          "source": "Financial",
          "description": "Annual operations and maintenance of smart grid infrastructure"
        },
        {
          "name": "Cumulative_Investment",
          "display_name": "Cumulative Smart Grid Investment",
          "type": "currency",
          "unit": "USD",
          "valid_range": { "min": 0, "max": 2000000000 },
          "source": "Financial",
          "description": "Total capital invested in smart grid deployment"
        }
      ],
      "benchmarks": {
        "typical_roi": 125,
        "payback_years": 8
      },
      "tags": ["smart-grid", "roi", "outage-reduction", "capex-deferral"]
    },
