      "tags": ["gross-margin", "cogs", "infrastructure", "efficiency", "profitability"]
    },
    {
      "formula_id": "sw-f-005",
      "name": "Platform Engineering ROI",
      "description": "Return on investment from internal developer platform including time savings from self-service, reduced incident response time, and infrastructure cost optimization.",
      "formula_type": "ROI",
      "version": "1.0.0",
      "status": "active",
      "governance": {
        "owner": "Platform Engineering",
        "review_cycle": "quarterly",
        "approval_status": "approved",
        "last_reviewed": "2026-04-11"
      },
      "expression": {
        "format": "STRING_EXPRESSION",
        "string": "(Developer_Hours_Saved_Per_Year * Fully_Loaded_Hourly_Rate + Infrastructure_Savings) / Platform_Investment * 100",
        "variables": [
          "Developer_Hours_Saved_Per_Year",
          "Fully_Loaded_Hourly_Rate",
          "Infrastructure_Savings",
          "Platform_Investment"
        ]
