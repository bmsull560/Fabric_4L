          "source": "Cloud_Billing",
          "description": "Annual savings from infrastructure optimization"
        },
        {
          "name": "Platform_Investment",
          "display_name": "Platform Engineering Investment",
          "type": "currency",
          "unit": "USD",
          "valid_range": { "min": 0, "max": 10000000 },
          "default_value": 2000000,
          "source": "Financial",
          "description": "Annual investment in platform team, tools, and infrastructure"
        }
      ],
      "benchmarks": {
        "typical_platform_roi": 300,
        "best_in_class": 500
