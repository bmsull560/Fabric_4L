{
  "pack_id": "software-v1",
  "formulas": [
    {
      "formula_id": "sw-f-001",
      "name": "Customer Acquisition Efficiency ROI",
      "description": "Return on investment from improving customer acquisition cost (CAC) through better targeting, automation, and conversion optimization. Value is created by acquiring the same number of customers with less spend, or more customers with the same spend.",
      "formula_type": "ROI",
      "version": "1.0.0",
      "status": "active",
      "governance": {
        "owner": "Software Value Engineering",
        "review_cycle": "quarterly",
        "approval_status": "approved",
        "last_reviewed": "2026-04-11",
        "validated_by": "SaaS Finance CoE"
      },
      "expression": {
        "format": "STRING_EXPRESSION",
        "string": "((Current_CAC - Target_CAC) * New_Customers_Per_Year - Program_Investment) / Program_Investment * 100",
        "variables": [
          "Current_CAC",
          "Target_CAC",
          "New_Customers_Per_Year",
          "Program_Investment"
        ]
      },
      "unit_of_result": "%",
      "precision": 1,
      "valid_range": {
        "min": -50,
        "max": 500
      },
      "required_variables": [
        {
          "name": "Current_CAC",
          "display_name": "Current Customer Acquisition Cost",
          "type": "currency",
          "unit": "USD",
          "valid_range": { "min": 0, "max": 100000 },
          "default_value": 25000,
          "source": "CRM",
          "description": "Current fully-loaded cost to acquire one new customer"
        },
        {
          "name": "Target_CAC",
          "display_name": "Target Customer Acquisition Cost",
          "type": "currency",
          "unit": "USD",
          "valid_range": { "min": 0, "max": 100000 },
          "default_value": 20000,
          "source": "Financial",
          "description": "Target CAC after efficiency improvements"
        },
        {
          "name": "New_Customers_Per_Year",
          "display_name": "Annual New Customer Acquisition",
          "type": "integer",
          "unit": "customers",
          "valid_range": { "min": 0, "max": 100000 },
          "default_value": 500,
          "source": "CRM",
          "description": "Number of new customers acquired annually"
        },
        {
          "name": "Program_Investment",
          "display_name": "CAC Improvement Program Investment",
          "type": "currency",
          "unit": "USD",
          "valid_range": { "min": 0, "max": 10000000 },
          "default_value": 500000,
          "source": "Financial",
          "description": "Annual investment in tools, talent, and programs to reduce CAC"
        }
      ],
      "benchmarks": {
        "typical_cac_improvement": 15,
        "best_in_class_cac_roi": 200
      },
      "tags": ["cac", "acquisition", "roi", "marketing", "efficiency"]
    },
    {
      "formula_id": "sw-f-002",
      "name": "Net Revenue Retention Improvement Value",
      "description": "Annual value created by improving Net Revenue Retention (NRR) through better expansion, reduced contraction, and lower churn. In SaaS, NRR above 100% means existing customers generate more revenue year-over-year.",
      "formula_type": "CUSTOM",
      "version": "1.0.0",
      "status": "active",
      "governance": {
        "owner": "Software Value Engineering",
        "review_cycle": "quarterly",
        "approval_status": "approved",
        "last_reviewed": "2026-04-11"
      },
      "expression": {
        "format": "STRING_EXPRESSION",
        "string": "Beginning_ARR * (Target_NRR - Current_NRR) / 100 - Implementation_Cost",
        "variables": [
          "Beginning_ARR",
          "Target_NRR",
          "Current_NRR",
          "Implementation_Cost"
        ]
      },
      "unit_of_result": "USD",
      "precision": 0,
      "valid_range": {
        "min": -10000000,
        "max": 500000000
      },
      "required_variables": [
        {
          "name": "Beginning_ARR",
          "display_name": "Beginning Annual Recurring Revenue",
          "type": "currency",
          "unit": "USD",
          "valid_range": { "min": 0, "max": 10000000000 },
          "source": "ERP",
          "description": "ARR at start of measurement period"
        },
        {
          "name": "Current_NRR",
          "display_name": "Current Net Revenue Retention",
          "type": "rate",
          "unit": "%",
          "valid_range": { "min": 50, "max": 150 },
          "default_value": 105,
          "source": "CRM",
          "description": "Current NRR percentage"
        },
        {
          "name": "Target_NRR",
          "display_name": "Target Net Revenue Retention",
          "type": "rate",
          "unit": "%",
          "valid_range": { "min": 50, "max": 150 },
          "default_value": 115,
          "source": "Financial",
          "description": "Target NRR after improvement initiatives"
        },
        {
          "name": "Implementation_Cost",
          "display_name": "NRR Program Implementation Cost",
          "type": "currency",
          "unit": "USD",
          "valid_range": { "min": 0, "max": 10000000 },
          "default_value": 750000,
          "source": "Financial",
          "description": "Annual cost of CS tools, headcount, and programs"
        }
      ],
      "benchmarks": {
        "best_in_class_nrr": 125,
        "good_nrr": 110,
        "average_nrr": 100
      },
      "tags": ["nrr", "retention", "expansion", "revenue", "saas-metrics"]
    },
    {
      "formula_id": "sw-f-003",
      "name": "Churn Reduction Value",
      "description": "Annual value of reducing customer churn rate. Each percentage point of churn reduction retains more customers and their associated revenue. This compounds over time as the customer base grows.",
      "formula_type": "CUSTOM",
      "version": "1.0.0",
      "status": "active",
      "governance": {
        "owner": "Customer Success Value Engineering",
        "review_cycle": "quarterly",
        "approval_status": "approved",
        "last_reviewed": "2026-04-11"
      },
      "expression": {
        "format": "STRING_EXPRESSION",
        "string": "Total_Customers * (Current_Churn_Rate - Target_Churn_Rate) / 100 * ACV * Avg_Customer_Lifespan_Years - Retention_Program_Cost",
        "variables": [
          "Total_Customers",
          "Current_Churn_Rate",
          "Target_Churn_Rate",
          "ACV",
          "Avg_Customer_Lifespan_Years",
          "Retention_Program_Cost"
        ]
      },
      "unit_of_result": "USD",
      "precision": 0,
      "valid_range": {
        "min": 0,
        "max": 100000000
      },
      "required_variables": [
        {
          "name": "Total_Customers",
          "display_name": "Total Customer Count",
          "type": "integer",
          "unit": "customers",
          "valid_range": { "min": 0, "max": 1000000 },
          "source": "CRM",
          "description": "Total number of active customers"
        },
        {
          "name": "Current_Churn_Rate",
          "display_name": "Current Annual Churn Rate",
          "type": "rate",
          "unit": "%",
          "valid_range": { "min": 0, "max": 50 },
          "default_value": 10,
          "source": "CRM",
          "description": "Current annual logo churn percentage"
        },
        {
          "name": "Target_Churn_Rate",
          "display_name": "Target Annual Churn Rate",
          "type": "rate",
          "unit": "%",
          "valid_range": { "min": 0, "max": 50 },
          "default_value": 7,
          "source": "Financial",
          "description": "Target churn rate after improvement programs"
        },
        {
          "name": "ACV",
          "display_name": "Average Contract Value",
          "type": "currency",
          "unit": "USD",
          "valid_range": { "min": 0, "max": 1000000 },
          "default_value": 50000,
          "source": "CRM",
          "description": "Average annual contract value per customer"
        },
        {
          "name": "Avg_Customer_Lifespan_Years",
          "display_name": "Average Customer Lifespan",
          "type": "float",
          "unit": "years",
          "valid_range": { "min": 0.5, "max": 20 },
          "default_value": 5,
          "source": "Calculated",
          "description": "Average customer tenure in years"
        },
        {
          "name": "Retention_Program_Cost",
          "display_name": "Customer Retention Program Cost",
          "type": "currency",
          "unit": "USD",
          "valid_range": { "min": 0, "max": 10000000 },
          "default_value": 400000,
          "source": "Financial",
          "description": "Annual cost of retention programs"
        }
      ],
      "benchmarks": {
        "best_in_class_churn": 5,
        "good_churn": 8,
        "average_churn": 12
      },
      "tags": ["churn", "retention", "customer-lifetime-value", "revenue-protection"]
    },
    {
