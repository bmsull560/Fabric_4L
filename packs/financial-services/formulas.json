{
  "pack_id": "financial-services-v1",
  "formulas": [
    {
      "formula_id": "fs-f-001",
      "name": "Fraud Detection ROI",
      "description": "Return on investment from AI-powered fraud detection including avoided fraud losses, reduced false positives, and operational efficiency gains in transaction monitoring.",
      "formula_type": "ROI",
      "version": "1.0.0",
      "status": "active",
      "governance": {
        "owner": "Risk Value Engineering",
        "review_cycle": "quarterly",
        "approval_status": "approved",
        "last_reviewed": "2026-04-15",
        "validated_by": "Risk Analytics CoE"
      },
      "expression": {
        "format": "STRING_EXPRESSION",
        "string": "(Avoided_Fraud_Losses + False_Positive_Savings + Operational_Savings - AI_Platform_Cost) / AI_Platform_Cost * 100",
        "variables": [
          "Avoided_Fraud_Losses",
          "False_Positive_Savings",
          "Operational_Savings",
          "AI_Platform_Cost"
        ]
      },
      "unit_of_result": "%",
      "precision": 1,
      "valid_range": {
        "min": -50,
        "max": 1000
      },
      "required_variables": [
        {
          "name": "Avoided_Fraud_Losses",
          "display_name": "Avoided Annual Fraud Losses",
          "type": "currency",
          "unit": "USD",
          "valid_range": { "min": 0, "max": 1000000000 },
          "source": "Risk_Analytics",
          "description": "Estimated fraud losses prevented by detection system"
        },
        {
          "name": "False_Positive_Savings",
          "display_name": "False Positive Reduction Savings",
          "type": "currency",
          "unit": "USD",
          "valid_range": { "min": 0, "max": 100000000 },
          "default_value": 5000000,
          "source": "Operations",
          "description": "Savings from reduced false positive reviews and customer friction"
        },
        {
          "name": "Operational_Savings",
          "display_name": "Operational Efficiency Savings",
          "type": "currency",
          "unit": "USD",
          "valid_range": { "min": 0, "max": 50000000 },
          "default_value": 3000000,
          "source": "Operations",
          "description": "Reduced manual review headcount and processing time"
        },
        {
          "name": "AI_Platform_Cost",
          "display_name": "AI Fraud Platform Annual Cost",
          "type": "currency",
          "unit": "USD",
          "valid_range": { "min": 0, "max": 100000000 },
          "default_value": 8000000,
          "source": "Financial",
          "description": "Annual cost of AI platform, infrastructure, and team"
        }
      ],
      "benchmarks": {
        "typical_roi": 350,
        "break_even_months": 6
      },
      "tags": ["fraud", "risk", "ai", "roi", "compliance"]
    },
    {
      "formula_id": "fs-f-002",
      "name": "Digital Onboarding Efficiency Value",
      "description": "Annual value from digitizing customer onboarding including reduced abandonment, faster time-to-revenue, and operational cost savings from automated KYC/AML processing.",
      "formula_type": "CUSTOM",
      "version": "1.0.0",
      "status": "active",
      "governance": {
        "owner": "Digital Value Engineering",
        "review_cycle": "quarterly",
        "approval_status": "approved",
        "last_reviewed": "2026-04-15"
      },
      "expression": {
        "format": "STRING_EXPRESSION",
        "string": "Additional_Customers_Acquired * First_Year_Revenue_Per_Customer + Operational_Savings - Digital_Onboarding_Investment",
        "variables": [
          "Additional_Customers_Acquired",
          "First_Year_Revenue_Per_Customer",
          "Operational_Savings",
          "Digital_Onboarding_Investment"
        ]
      },
      "unit_of_result": "USD",
      "precision": 0,
      "valid_range": {
        "min": -5000000,
        "max": 200000000
      },
      "required_variables": [
        {
          "name": "Additional_Customers_Acquired",
          "display_name": "Additional Customers from Reduced Abandonment",
          "type": "integer",
          "unit": "customers",
          "valid_range": { "min": 0, "max": 1000000 },
          "default_value": 5000,
          "source": "Digital_Analytics",
          "description": "Additional customers completing onboarding due to digital improvements"
        },
        {
          "name": "First_Year_Revenue_Per_Customer",
          "display_name": "First Year Revenue per Customer",
          "type": "currency",
          "unit": "USD",
          "valid_range": { "min": 0, "max": 100000 },
          "default_value": 2500,
          "source": "Finance",
          "description": "Average revenue generated from new customer in first year"
        },
        {
          "name": "Operational_Savings",
          "display_name": "Operational Cost Savings",
          "type": "currency",
          "unit": "USD",
          "valid_range": { "min": 0, "max": 50000000 },
          "default_value": 5000000,
          "source": "Operations",
          "description": "Savings from automated KYC/AML vs manual processing"
        },
        {
          "name": "Digital_Onboarding_Investment",
          "display_name": "Digital Onboarding Platform Investment",
          "type": "currency",
          "unit": "USD",
          "valid_range": { "min": 0, "max": 50000000 },
          "default_value": 8000000,
          "source": "Financial",
          "description": "Annual investment in digital onboarding platform and operations"
        }
      ],
      "benchmarks": {
        "digital_abandonment_rate": 25,
        "manual_abandonment_rate": 60
      },
      "tags": ["onboarding", "digital", "kyc", "aml", "customer-acquisition"]
    },
    {
      "formula_id": "fs-f-003",
      "name": "Credit Risk Model Improvement Value",
      "description": "Value from improving credit risk models through better data and ML techniques including reduced default rates, optimized pricing, and expanded profitable lending.",
      "formula_type": "CUSTOM",
      "version": "1.0.0",
      "status": "active",
      "governance": {
        "owner": "Credit Risk Value Engineering",
        "review_cycle": "quarterly",
        "approval_status": "approved",
        "last_reviewed": "2026-04-15"
      },
      "expression": {
        "format": "STRING_EXPRESSION",
        "string": "Loan_Portfolio_Value * (Baseline_Default_Rate - Target_Default_Rate) / 100 + Expanded_Lending_Profit - Model_Investment",
        "variables": [
          "Loan_Portfolio_Value",
          "Baseline_Default_Rate",
          "Target_Default_Rate",
          "Expanded_Lending_Profit",
          "Model_Investment"
        ]
      },
      "unit_of_result": "USD",
      "precision": 0,
      "valid_range": {
        "min": -10000000,
        "max": 500000000
      },
      "required_variables": [
        {
          "name": "Loan_Portfolio_Value",
          "display_name": "Total Loan Portfolio Value",
          "type": "currency",
          "unit": "USD",
          "valid_range": { "min": 0, "max": 100000000000 },
          "source": "Risk_Systems",
          "description": "Total value of loan portfolio being assessed"
        },
        {
          "name": "Baseline_Default_Rate",
          "display_name": "Baseline Default Rate",
          "type": "rate",
          "unit": "%",
          "valid_range": { "min": 0, "max": 20 },
          "default_value": 3.5,
          "source": "Risk_Analytics",
          "description": "Current portfolio default rate percentage"
        },
        {
          "name": "Target_Default_Rate",
          "display_name": "Target Default Rate",
          "type": "rate",
          "unit": "%",
          "valid_range": { "min": 0, "max": 20 },
          "default_value": 2.8,
          "source": "Risk_Analytics",
          "description": "Target default rate with improved models"
        },
        {
          "name": "Expanded_Lending_Profit",
          "display_name": "Profit from Expanded Lending",
          "type": "currency",
          "unit": "USD",
          "valid_range": { "min": 0, "max": 100000000 },
          "default_value": 10000000,
          "source": "Finance",
          "description": "Additional profit from lending to previously underserved segments"
        },
        {
          "name": "Model_Investment",
          "display_name": "Credit Model Investment",
          "type": "currency",
          "unit": "USD",
          "valid_range": { "min": 0, "max": 50000000 },
          "default_value": 5000000,
          "source": "Financial",
          "description": "Annual investment in data, models, and infrastructure"
        }
      ],
      "benchmarks": {
        "typical_default_improvement": 0.5,
        "best_in_class_default_rate": 1.5
      },
      "tags": ["credit-risk", "lending", "default-rate", "ml-models"]
    },
