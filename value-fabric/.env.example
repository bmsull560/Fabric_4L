# Value Fabric — Backend Environment Contract
# Copy this file to .env and fill in real values for local development.
# DO NOT commit .env files with real secrets to version control.
#
# Variable Classification:
#   Class A — Secret, backend-only (Infisical-injected, never committed)
#   Class B — Sensitive but non-secret backend config
#   Class C — Public frontend config (VITE_* prefix only)
#   Class D — Local-only developer convenience

# =============================================================================
# Infisical Secrets Manager (Class A)
# When all four vars below are set, secrets are fetched from Infisical at
# startup and injected into the process before pydantic-settings reads them.
# Leave blank to fall back to plain environment variables (local dev default).
# =============================================================================
INFISICAL_CLIENT_ID=
INFISICAL_CLIENT_SECRET=
INFISICAL_PROJECT_ID=
# Environment slug: Development | Staging | Production
INFISICAL_ENVIRONMENT=dev
# Self-hosted only — omit to use Infisical Cloud (https://app.infisical.com)
INFISICAL_HOST=
# Secret path within the project (default: /)
INFISICAL_SECRET_PATH=/
# Set to "true" to let Infisical values overwrite vars already in the process env
INFISICAL_OVERWRITE=false

# =============================================================================
# Runtime (Class B)
# =============================================================================
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# =============================================================================
# REQUIRED: LLM API Keys (Class A — Secret)
# =============================================================================
# OpenAI API Key - Required for L1 (ingestion), L2 (extraction), L4 (agents)
OPENAI_API_KEY=sk-your-openai-key-here

# =============================================================================
# VAULT & SECRETS (Class A / B)
# =============================================================================
VAULT_ADDR=
API_KEY_HMAC_SECRET=<generate-with-openssl-rand-hex-32>

# Service-to-service authentication secret (F-1 P0 fix)
# Required for X-Tenant-ID header authentication between internal services.
# All internal services must share this secret to call each other.
# Generate with: openssl rand -hex 32
SERVICE_AUTH_SECRET=<generate-with-openssl-rand-hex-32>

# =============================================================================
# OPTIONAL: Alternative LLM Providers (Class A — Secret)
# =============================================================================
# Anthropic API Key - Optional alternative for L4 agents
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here

# LLM Model Selection - Defaults to gpt-4o if not specified
LLM_MODEL=gpt-4o

# =============================================================================
# OPTIONAL: External Service Integrations (Class A — Secret)
# =============================================================================
# Pinecone API Key - Required only if using vector search in L3
PINECONE_API_KEY=
PINECONE_INDEX=

# Browserbase API Key - Optional for L1 browser automation
BROWSERBASE_API_KEY=

# Firecrawl API Key - Optional for L1 web scraping
FIRECRAWL_API_KEY=

# Thesys C1 API Key - Optional for L4 generative UI
THESYS_API_KEY=

# =============================================================================
# DATABASE & INFRASTRUCTURE (Class B — Local Development Defaults)
# =============================================================================
# Neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
# REQUIRED: Generate with: openssl rand -hex 16
NEO4J_PASSWORD=REPLACE_WITH_GENERATED_SECRET

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=valuefabric

# Redis
REDIS_URL=redis://localhost:6379/0

# =============================================================================
# AUTH (Class A — Secret)
# =============================================================================
# JWT Secret for authentication - Generate with: openssl rand -hex 32
# REQUIRED: Minimum 32 characters
JWT_SECRET=REPLACE_WITH_OPENSSL_RAND_HEX_32_OUTPUT

# OIDC default redirect URI (Class B)
OIDC_DEFAULT_REDIRECT_URI=https://localhost:3000/auth/callback

# =============================================================================
# OPTIONAL: Inter-layer auth (Class A — Secret)
# =============================================================================
LAYER3_API_KEY=

# =============================================================================
# OPTIONAL: CRM Integration (Class B / A)
# =============================================================================
# CRM Provider Type - 'salesforce', 'hubspot', or 'none'
CRM_TYPE=none

# CRM API Key - OAuth token for Salesforce, API key for HubSpot (Class A)
CRM_API_KEY=

# CRM API Secret - OAuth refresh token for Salesforce (Class A)
CRM_API_SECRET=

# CRM Instance URL (Class B)
CRM_INSTANCE_URL=

# CRM Sync Configuration (Class B)
CRM_SYNC_BATCH_SIZE=100
CRM_SYNC_INTERVAL_MINUTES=60

# =============================================================================
# OPTIONAL: Stripe Billing Integration (Class A — Secret)
# =============================================================================
# Stripe API Keys - Required for billing/subscription management
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_signing_secret
STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key

# Stripe Price IDs - Configure in Stripe Dashboard
STRIPE_PRICE_PRO=price_your_pro_plan_price_id
STRIPE_PRICE_ENTERPRISE=price_your_enterprise_plan_price_id

# =============================================================================
# OPTIONAL: Export Object Storage (S3 / MinIO) (Class A / B)
# =============================================================================
# If unset, export endpoints will fail closed with 503.
LAYER4_EXPORT_STORAGE_ENDPOINT=http://localhost:9000
LAYER4_EXPORT_STORAGE_REGION=us-east-1
LAYER4_EXPORT_STORAGE_BUCKET=value-fabric-exports
LAYER4_EXPORT_STORAGE_ACCESS_KEY=minioadmin
LAYER4_EXPORT_STORAGE_SECRET_KEY=minioadmin
LAYER4_EXPORT_STORAGE_USE_SSL=false
LAYER4_EXPORT_SIGNED_URL_TTL_SECONDS=900
