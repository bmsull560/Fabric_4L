# Value Fabric Environment Configuration
# Copy this file to .env and fill in real values for local development
# DO NOT commit .env files with real secrets to version control

# =============================================================================
# REQUIRED: LLM API Keys
# =============================================================================
# OpenAI API Key - Required for L1 (ingestion), L2 (extraction), L4 (agents)
OPENAI_API_KEY=sk-your-openai-key-here

# =============================================================================
# VAULT & SECRETS
# =============================================================================
VAULT_ADDR=
API_KEY_HMAC_SECRET=

# =============================================================================
# OPTIONAL: Alternative LLM Providers
# =============================================================================
# Anthropic API Key - Optional alternative for L4 agents
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here

# LLM Model Selection - Defaults to gpt-4o if not specified
LLM_MODEL=gpt-4o

# =============================================================================
# OPTIONAL: External Service Integrations
# =============================================================================
# Pinecone API Key - Required only if using vector search in L3
PINECONE_API_KEY=
PINECONE_INDEX=

# Browserbase API Key - Optional for L1 browser automation
BROWSERBASE_API_KEY=

# Firecrawl API Key - Optional for L1 web scraping
FIRECRAWL_API_KEY=

# =============================================================================
# DATABASE & INFRASTRUCTURE (Local Development Defaults)
# =============================================================================
# These use Docker Compose service names - do not change for local dev
NEO4J_PASSWORD=valuefabric

# JWT Secret for L5 authentication
# Generate with: openssl rand -hex 32
JWT_SECRET=changeme-in-production-generate-strong-secret

# OIDC default redirect URI
OIDC_DEFAULT_REDIRECT_URI=https://localhost:3000/auth/callback

# =============================================================================
# OPTIONAL: Layer 3 API Key (for L5 integration)
# =============================================================================
LAYER3_API_KEY=

# =============================================================================
# OPTIONAL: CRM Integrations (Salesforce / HubSpot)
# =============================================================================
# Enable CRM integration for Account sync and prospect data
# CRM_TYPE: 'salesforce' or 'hubspot'
CRM_TYPE=

# Salesforce Configuration
# CRM_API_KEY: Salesforce OAuth access token or session ID
# CRM_API_SECRET: Salesforce OAuth refresh token (for automatic refresh)
# CRM_INSTANCE_URL: Your Salesforce instance URL (e.g., https://yourinstance.salesforce.com)
CRM_API_KEY=
CRM_API_SECRET=
CRM_INSTANCE_URL=

# HubSpot Configuration
# CRM_API_KEY: HubSpot private app access token or OAuth token
# HubSpot does not require separate secret or instance URL
# For HubSpot, only CRM_TYPE and CRM_API_KEY are needed

# CRM Sync Configuration
# CRM_SYNC_INTERVAL_MINUTES: How often to sync accounts (default: 60)
CRM_SYNC_INTERVAL_MINUTES=60
# CRM_SYNC_BATCH_SIZE: Number of accounts per sync batch (default: 100)
CRM_SYNC_BATCH_SIZE=100

# =============================================================================
# LOGGING
# =============================================================================
LOG_LEVEL=info
