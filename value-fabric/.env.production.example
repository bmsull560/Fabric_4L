# Value Fabric — Production Environment Contract
# This file defines the exact shape of production configuration.
# NO real secrets — every Class A value is a placeholder.
# Real values are injected by Infisical at runtime.

# =============================================================================
# Runtime
# =============================================================================
NODE_ENV=production
PORT=3000
LOG_LEVEL=warn

# =============================================================================
# LLM API Keys (Class A — injected by Infisical)
# =============================================================================
OPENAI_API_KEY=<injected-by-infisical>
ANTHROPIC_API_KEY=<injected-by-infisical>

# =============================================================================
# Auth & Security (Class A — injected by Infisical)
# =============================================================================
JWT_SECRET=<injected-by-infisical>
API_KEY_HMAC_SECRET=<injected-by-infisical>

# =============================================================================
# Databases (Class B — production endpoints)
# =============================================================================
NEO4J_URI=bolt://neo4j-prod:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=<injected-by-infisical>

POSTGRES_HOST=postgres-prod
POSTGRES_PORT=5432
POSTGRES_USER=valuefabric
POSTGRES_PASSWORD=<injected-by-infisical>
POSTGRES_DB=valuefabric

REDIS_URL=redis://redis-prod:6379/0

# =============================================================================
# Vault & External Services (Class B)
# =============================================================================
VAULT_ADDR=https://vault.internal:8200

# =============================================================================
# CRM Integration (Class B)
# =============================================================================
CRM_TYPE=none
CRM_API_KEY=<injected-by-infisical>
CRM_API_SECRET=<injected-by-infisical>
CRM_INSTANCE_URL=
CRM_SYNC_BATCH_SIZE=100
CRM_SYNC_INTERVAL_MINUTES=60

# =============================================================================
# Optional Integrations (Class A — injected by Infisical)
# =============================================================================
PINECONE_API_KEY=<injected-by-infisical>
PINECONE_INDEX=
BROWSERBASE_API_KEY=<injected-by-infisical>
FIRECRAWL_API_KEY=<injected-by-infisical>

# =============================================================================
# OIDC (Class B)
# =============================================================================
OIDC_DEFAULT_REDIRECT_URI=https://app.valuefabric.com/auth/callback

# =============================================================================
# Thesys C1 (Class A — injected by Infisical)
# =============================================================================
THESYS_API_KEY=<injected-by-infisical>
