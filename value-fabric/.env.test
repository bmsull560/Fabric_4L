# Value Fabric — Test Environment Configuration
# Deterministic, offline-safe values for CI and local test runs.
# No real secrets — all credentials are fakes.

# =============================================================================
# Runtime
# =============================================================================
NODE_ENV=test
PORT=3000
LOG_LEVEL=warn

# =============================================================================
# LLM API Keys (Class A — fakes for test)
# =============================================================================
OPENAI_API_KEY=sk-test-fake-openai-key-00000000000000000000
ANTHROPIC_API_KEY=sk-ant-test-fake-anthropic-key-00000000000

# =============================================================================
# Auth & Security (Class A — fakes for test)
# =============================================================================
JWT_SECRET=test-jwt-secret-must-be-at-least-32-characters-long
API_KEY_HMAC_SECRET=test-hmac-secret-must-be-at-least-32-characters-long

# =============================================================================
# Databases — localhost (Class B)
# =============================================================================
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=testpassword

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=valuefabric_test

REDIS_URL=redis://localhost:6379/1

# =============================================================================
# Vault & External Services (Class B — disabled in test)
# =============================================================================
VAULT_ADDR=http://localhost:8200

# =============================================================================
# CRM Integration (Class B — disabled in test)
# =============================================================================
CRM_TYPE=none

# =============================================================================
# Optional Integrations (Class A — disabled in test)
# =============================================================================
PINECONE_API_KEY=
BROWSERBASE_API_KEY=
FIRECRAWL_API_KEY=

# =============================================================================
# OIDC (Class B — disabled in test)
# =============================================================================
OIDC_DEFAULT_REDIRECT_URI=http://localhost:3000/auth/callback
