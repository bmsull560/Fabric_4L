# Root-level dockerignore for multi-layer builds with parent context
# See: https://docs.docker.com/engine/reference/builder/#dockerignore-file

# Git
.git
.gitignore
.gitattributes

# IDE
.idea
.vscode
*.swp
*.swo
*~

# Python cache
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.mypy_cache/
.ruff_cache/
.pytest_cache/
*.egg-info/
dist/
build/

# Node (frontend)
node_modules/
frontend/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Local env files (security - never copy secrets)
.env
.env.local
.env.*.local
!.env.example
!.env.production.example

# Documentation that shouldn't be in images
*.md
!README.md
LICENSE
CHANGELOG
CONTRIBUTING

# CI/CD
.github/
.gitlab-ci.yml
.travis.yml
azure-pipelines.yml

# Docker (avoid recursive issues)
docker-compose*.yml
Dockerfile*
.dockerignore

# OS files
.DS_Store
Thumbs.db

# Temporary files
*.tmp
*.temp
*.bak
