# Value Fabric Frontend Environment Variables

# ============================================
# API Configuration
# ============================================
# Base API path for all backend layers
# Note: Backend OpenAPI routes include /v1 prefix (e.g., /v1/graph/subgraph)
# Layer prefixes do NOT include /v1 — it lives in VITE_API_BASE.
VITE_API_BASE=/api/v1

# Layer-specific browser prefixes (no /v1 — handled by VITE_API_BASE)
VITE_L1_PREFIX=/ingest
VITE_L2_PREFIX=/extract
VITE_L3_PREFIX=/graph
VITE_L4_PREFIX=/agents
VITE_L5_PREFIX=/truths
VITE_L6_PREFIX=/benchmarks

# Live/dev-server proxy targets. Local defaults match the backend-integrated
# stack published ports; docker-compose.live.yml overrides these with Docker
# service names inside the live network.
VITE_API_BASE_URL=http://localhost:8004
VITE_PROXY_L1_URL=http://localhost:8001
VITE_PROXY_L2_URL=http://localhost:8002
VITE_PROXY_L3_URL=http://localhost:8003
VITE_PROXY_L4_URL=http://localhost:8004
VITE_PROXY_L5_URL=http://localhost:8005
VITE_PROXY_L6_URL=http://localhost:8006

# ============================================
# CRM Integration
# ============================================
# Enable CRM sync features (Salesforce, HubSpot, etc.)
VITE_ENABLE_CRM_SYNC=false
# Default CRM provider (salesforce, hubspot, pipedrive, zoho)
VITE_CRM_PROVIDER=salesforce
# CRM API endpoint (server-side proxy)
VITE_CRM_API_PROXY=/api/crm

# ============================================
# Thesys C1 Generative UI Integration
# ============================================
# Enable interactive AI-powered business case exploration.
# The API key is kept server-side (THESYS_API_KEY env var on L4).
# The frontend only needs the feature flag below.
VITE_ENABLE_C1_REPORTS=false

# ============================================
# Development / Testing
# ============================================
# Enable mock API responses (useful for frontend development without backend).
# Live validation commands fail closed if either mock flag is enabled.
VITE_USE_MOCKS=false
VITE_ENABLE_MOCK_FALLBACK=false
