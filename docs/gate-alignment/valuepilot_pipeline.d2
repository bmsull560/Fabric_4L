direction: down

# ---------------------------------------------------------------
# Title
# ---------------------------------------------------------------
title: {
  label: "ValuePilot Pipeline — Data Flow"
  near: top-center
  shape: text
  style: {
    font-size: 28
    bold: true
    font-color: "#1a1a2e"
  }
}

# ---------------------------------------------------------------
# Layer 1 — Frontend
# ---------------------------------------------------------------
frontend: {
  label: "Frontend (Browser)"
  style: {
    fill: "#e8f4fd"
    stroke: "#2196f3"
    border-radius: 12
    font-size: 16
    bold: true
  }

  rightrail: {
    label: "RightRail Chat Panel"
    shape: rectangle
    style: {
      fill: "#bbdefb"
      stroke: "#1976d2"
      font-size: 14
    }
  }

  hook: {
    label: "useAgentStream Hook"
    shape: rectangle
    style: {
      fill: "#bbdefb"
      stroke: "#1976d2"
      font-size: 14
    }
  }

  rightrail -> hook: "user message + activeTab + account"
}

# ---------------------------------------------------------------
# Layer 2 — API Gateway
# ---------------------------------------------------------------
api: {
  label: "FastAPI Application (Layer 4)"
  style: {
    fill: "#fff3e0"
    stroke: "#ff9800"
    border-radius: 12
    font-size: 16
    bold: true
  }

  middleware: {
    label: "Middleware Stack"
    shape: rectangle
    style: {
      fill: "#ffe0b2"
      stroke: "#f57c00"
      font-size: 13
    }
  }

  mw_items: {
    label: |md
      RequestIDMiddleware
      GovernanceMiddleware
      require_authenticated
    |
    shape: rectangle
    style: {
      fill: "#fff8e1"
      stroke: "#ffa726"
      font-size: 12
    }
  }

  route: {
    label: "POST /v1/agent-stream/chat"
    shape: rectangle
    style: {
      fill: "#ffe0b2"
      stroke: "#f57c00"
      font-size: 14
      bold: true
    }
  }

  middleware -> mw_items: "populates"
  mw_items -> route: "RequestContext + trace_id"
}

# ---------------------------------------------------------------
# Layer 3 — ConversationService Pipeline
# ---------------------------------------------------------------
pipeline: {
  label: "ConversationService Pipeline"
  style: {
    fill: "#e8f5e9"
    stroke: "#4caf50"
    border-radius: 12
    font-size: 16
    bold: true
  }

  step1: {
    label: "Step 1: Classify Intent"
    shape: rectangle
    style: {
      fill: "#c8e6c9"
      stroke: "#388e3c"
      font-size: 14
      bold: true
    }
  }

  step1_detail: {
    label: |md
      ConversationAgent.execute(classify_intent)
      or heuristic fallback
      6 intents: value_analysis, competitive_intel,
      document_export, workflow_status,
      account_inquiry, general_question
    |
    shape: rectangle
    style: {
      fill: "#e8f5e9"
      stroke: "#66bb6a"
      font-size: 11
    }
  }

  step2: {
    label: "Step 2: Gather Context"
    shape: rectangle
    style: {
      fill: "#c8e6c9"
      stroke: "#388e3c"
      font-size: 14
      bold: true
    }
  }

  step2_detail: {
    label: |md
      ConversationAgent.execute(gather_context)
      Account data, entities, relationships
    |
    shape: rectangle
    style: {
      fill: "#e8f5e9"
      stroke: "#66bb6a"
      font-size: 11
    }
  }

  decision: {
    label: "Step 3: Route by Intent"
    shape: diamond
    style: {
      fill: "#fff9c4"
      stroke: "#f9a825"
      font-size: 13
      bold: true
    }
  }

  step4: {
    label: "Step 4: Generate Response"
    shape: rectangle
    style: {
      fill: "#c8e6c9"
      stroke: "#388e3c"
      font-size: 14
      bold: true
    }
  }

  step4_detail: {
    label: |md
      Priority cascade:
      1. ConversationAgent.execute(chat)
      2. C1 Proxy LLM generation
      3. Heuristic response (always works)
    |
    shape: rectangle
    style: {
      fill: "#e8f5e9"
      stroke: "#66bb6a"
      font-size: 11
    }
  }

  step5: {
    label: "Step 5: Emit Audit Event"
    shape: rectangle
    style: {
      fill: "#c8e6c9"
      stroke: "#388e3c"
      font-size: 14
      bold: true
    }
  }

  step5_detail: {
    label: |md
      CONVERSATION_INTERACTION
      chain_id: conversation:{tenant_id}
    |
    shape: rectangle
    style: {
      fill: "#e8f5e9"
      stroke: "#66bb6a"
      font-size: 11
    }
  }

  step1 -> step1_detail
  step1 -> step2: "intent + confidence + entities"
  step2 -> step2_detail
  step2 -> decision: "context_data"
  decision -> step4: "all intents"
  step4 -> step4_detail
  step4 -> step5: "response content"
  step5 -> step5_detail
}

# ---------------------------------------------------------------
# Layer 4 — Workflow Delegation
# ---------------------------------------------------------------
workflow: {
  label: "Workflow Delegation"
  style: {
    fill: "#f3e5f5"
    stroke: "#9c27b0"
    border-radius: 12
    font-size: 16
    bold: true
  }

  orch: {
    label: "OrchestrationController"
    shape: rectangle
    style: {
      fill: "#e1bee7"
      stroke: "#7b1fa2"
      font-size: 14
      bold: true
    }
  }

  workflows: {
    label: |md
      full_value_spine
      competitive_analysis
      narrative_export
    |
    shape: rectangle
    style: {
      fill: "#f3e5f5"
      stroke: "#ab47bc"
      font-size: 12
    }
  }

  spine: {
    label: "Value Spine Agents"
    shape: rectangle
    style: {
      fill: "#e1bee7"
      stroke: "#7b1fa2"
      font-size: 13
    }
  }

  spine_list: {
    label: |md
      ContextExtractionAgent
      ValueModelAgent
      IntegrityAgent
      NarrativeAgent
      CompetitiveIntelAgent
    |
    shape: rectangle
    style: {
      fill: "#f3e5f5"
      stroke: "#ab47bc"
      font-size: 11
    }
  }

  orch -> workflows: "schedule_workflow()"
  workflows -> spine: "dispatches"
  spine -> spine_list
}

# ---------------------------------------------------------------
# Layer 5 — GATE Framework
# ---------------------------------------------------------------
gate: {
  label: "GATE Framework (Cross-Cutting)"
  style: {
    fill: "#fce4ec"
    stroke: "#e53935"
    border-radius: 12
    font-size: 16
    bold: true
  }

  tool_gw: {
    label: "ToolGateway"
    shape: rectangle
    style: {
      fill: "#ffcdd2"
      stroke: "#c62828"
      font-size: 13
      bold: true
    }
  }

  policy: {
    label: "PolicyEngineClient (OPA)"
    shape: rectangle
    style: {
      fill: "#ffcdd2"
      stroke: "#c62828"
      font-size: 12
    }
  }

  invariants: {
    label: "InvariantEvaluator"
    shape: rectangle
    style: {
      fill: "#ffcdd2"
      stroke: "#c62828"
      font-size: 12
    }
  }

  memory_gw: {
    label: "MemoryGateway"
    shape: rectangle
    style: {
      fill: "#ffcdd2"
      stroke: "#c62828"
      font-size: 12
    }
  }

  replay: {
    label: "ReplayRecorder"
    shape: rectangle
    style: {
      fill: "#ffcdd2"
      stroke: "#c62828"
      font-size: 12
    }
  }

  ledger: {
    label: "Audit Ledger (hash-chained)"
    shape: cylinder
    style: {
      fill: "#ffcdd2"
      stroke: "#c62828"
      font-size: 12
    }
  }

  tool_gw -> policy: "check policy"
  tool_gw -> invariants: "check limits"
  tool_gw -> ledger: "TOOL_INVOCATION"
  memory_gw -> ledger: "MEMORY_ACCESS"
  replay -> ledger: "REPLAY_SNAPSHOT"
}

# ---------------------------------------------------------------
# Layer 6 — External Services
# ---------------------------------------------------------------
external: {
  label: "External Services"
  style: {
    fill: "#efebe9"
    stroke: "#795548"
    border-radius: 12
    font-size: 16
    bold: true
  }

  c1: {
    label: "Thesys C1 Proxy (LLM)"
    shape: rectangle
    style: {
      fill: "#d7ccc8"
      stroke: "#5d4037"
      font-size: 13
      bold: true
    }
  }

  neo4j: {
    label: "Neo4j Knowledge Graph"
    shape: cylinder
    style: {
      fill: "#d7ccc8"
      stroke: "#5d4037"
      font-size: 12
    }
  }

  crm: {
    label: "CRM (Salesforce/HubSpot)"
    shape: cylinder
    style: {
      fill: "#d7ccc8"
      stroke: "#5d4037"
      font-size: 12
    }
  }
}

# ---------------------------------------------------------------
# Connections — Main Flow
# ---------------------------------------------------------------
frontend.hook -> api.middleware: "POST /v1/agent-stream/chat" {
  style: {
    stroke: "#1976d2"
    stroke-width: 2
  }
}

api.route -> pipeline.step1: "user_message, messages, active_tab, account, tenant_id, trace_id" {
  style: {
    stroke: "#388e3c"
    stroke-width: 2
  }
}

pipeline.decision -> workflow.orch: "confidence >= 0.7 and workflow intent" {
  style: {
    stroke: "#7b1fa2"
    stroke-width: 2
    stroke-dash: 5
  }
}

pipeline.step4 -> external.c1: "enriched system prompt + messages (Strategy 2)" {
  style: {
    stroke: "#5d4037"
    stroke-width: 2
    stroke-dash: 5
  }
}

external.c1 -> pipeline.step4: "LLM response" {
  style: {
    stroke: "#5d4037"
    stroke-width: 1
    stroke-dash: 5
  }
}

pipeline.step5 -> gate.ledger: "CONVERSATION_INTERACTION event" {
  style: {
    stroke: "#e53935"
    stroke-width: 2
  }
}

# GATE governs all agent execute() calls
pipeline.step1 -> gate.tool_gw: "agent.execute() via GATE" {
  style: {
    stroke: "#e53935"
    stroke-width: 1
    stroke-dash: 3
  }
}

pipeline.step2 -> gate.tool_gw: "agent.execute() via GATE" {
  style: {
    stroke: "#e53935"
    stroke-width: 1
    stroke-dash: 3
  }
}

workflow.spine -> gate.tool_gw: "all tool calls via GATE" {
  style: {
    stroke: "#e53935"
    stroke-width: 1
    stroke-dash: 3
  }
}

workflow.spine -> gate.memory_gw: "all retrievals via GATE" {
  style: {
    stroke: "#e53935"
    stroke-width: 1
    stroke-dash: 3
  }
}

gate.tool_gw -> external.neo4j: "query_graph, semantic_search" {
  style: {
    stroke: "#795548"
    stroke-width: 1
  }
}

gate.tool_gw -> external.crm: "export_to_crm, sync_crm_record" {
  style: {
    stroke: "#795548"
    stroke-width: 1
  }
}

gate.memory_gw -> external.neo4j: "provenance-tracked retrieval" {
  style: {
    stroke: "#795548"
    stroke-width: 1
  }
}

# Response flow back
pipeline.step5 -> api.route: "content + metadata" {
  style: {
    stroke: "#388e3c"
    stroke-width: 2
  }
}

api.route -> frontend.hook: "AgentStreamResponse" {
  style: {
    stroke: "#1976d2"
    stroke-width: 2
  }
}
