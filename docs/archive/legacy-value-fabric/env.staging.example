<!-- Migrated from services/env.staging.example during legacy path cleanup. -->

# Value Fabric — Staging Environment Configuration
# Same shape as production with placeholder secrets.
# Real values are injected by Infisical at runtime.

# =============================================================================
# Runtime
# =============================================================================
NODE_ENV=staging
PORT=3000
LOG_LEVEL=info

# =============================================================================
# LLM API Keys (Class A — injected by Infisical)
# =============================================================================
OPENAI_API_KEY=<injected-by-infisical>
ANTHROPIC_API_KEY=<injected-by-infisical>

# =============================================================================
# Auth & Security (Class A — injected by Infisical)
# =============================================================================
JWT_SECRET=<injected-by-infisical>
API_KEY_HMAC_SECRET=<injected-by-infisical>

# =============================================================================
# Databases (Class B — staging endpoints)
# =============================================================================
NEO4J_URI=bolt://neo4j-staging:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=<injected-by-infisical>

POSTGRES_HOST=postgres-staging
POSTGRES_PORT=5432
POSTGRES_USER=valuefabric
POSTGRES_PASSWORD=<injected-by-infisical>
POSTGRES_DB=valuefabric_staging

REDIS_URL=redis://redis-staging:6379/0

# =============================================================================
# Vault & External Services (Class B)
# =============================================================================
VAULT_ADDR=https://vault-staging.internal:8200

# =============================================================================
# CRM Integration (Class B)
# =============================================================================
CRM_TYPE=none
CRM_API_KEY=
CRM_INSTANCE_URL=

# =============================================================================
# Optional Integrations (Class A — injected by Infisical)
# =============================================================================
PINECONE_API_KEY=<injected-by-infisical>
BROWSERBASE_API_KEY=
FIRECRAWL_API_KEY=

# =============================================================================
# OIDC (Class B)
# =============================================================================
OIDC_DEFAULT_REDIRECT_URI=https://staging.valuefabric.app/auth/callback
