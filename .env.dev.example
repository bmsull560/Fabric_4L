# =============================================================================
# Value Fabric — Local Dev Environment
# =============================================================================
# Copy this file to .env.dev and optionally add your LLM API keys.
# No keys required — ValuePilot runs in heuristic mode by default.
#
# Usage:
#   cp .env.dev.example .env.dev
#   ./scripts/dev-up.sh --build
# =============================================================================

# OpenAI API Key (optional) — Uncomment and set for real LLM responses
# OPENAI_API_KEY=

# Anthropic API Key (optional) — Alternative LLM provider
# ANTHROPIC_API_KEY=sk-ant-your-key-here

# LLM Model (optional) — Defaults to gpt-4o
# LLM_MODEL=gpt-4o

# Thesys API Key (optional) — For generative UI features
# THESYS_API_KEY=

# Auth bypass for local development only — never set in staging/production.
# Canonical flag (use this):
# ALLOW_INSECURE_DEV_AUTH_BYPASS=true
#
# Deprecated aliases (emit DeprecationWarning at startup, will be removed):
# DEV_AUTH_BYPASS=true
# AUTH_BYPASS_ENABLED=true
# ALLOW_DEV_AUTH_BYPASS=I_UNDERSTAND_RISK

# Docker Base Image Override — uncomment to use the public image locally.
# Leave unset to use the Dockerfile default (private GHCR image).
BASE_IMAGE=python:3.11.11-slim-bookworm

# CORS origins — not required in development (services default to localhost dev servers).
# Set explicitly to override the default localhost:5173 / localhost:3000 fallback.
# CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# =============================================================================
# Infrastructure Secrets — Dev-only defaults. NEVER use in production.
# =============================================================================
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
NEO4J_AUTH=neo4j/devpassword
NEO4J_PASSWORD=devpassword

# =============================================================================
# Auth Secrets — Dev-only defaults. NEVER use in production.
# =============================================================================
JWT_SECRET=dev-local-secret-do-not-use-in-production-minimum-32-chars

# =============================================================================
# Service Database URLs — Dev-only defaults. NEVER use in production.
# =============================================================================
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/valuefabric
LAYER1_DATABASE_URL=postgresql://postgres:postgres@postgres:5432/ingestion
LAYER2_DATABASE_URL=postgresql://postgres:postgres@postgres:5432/layer2_extraction
LAYER4_DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/layer4_agents
CHECKPOINT_DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/ground_truth
SIGNAL_REFINERY_DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/signal_refinery
LAYER6_DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/layer6_benchmarks