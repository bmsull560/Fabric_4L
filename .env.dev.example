# =============================================================================
# Value Fabric — Local Dev Environment
# =============================================================================
# Copy this file to .env.dev and optionally add your LLM API keys.
# No keys required — ValuePilot runs in heuristic mode by default.
#
# Usage:
#   cp .env.dev.example .env.dev
#   ./scripts/dev-up.sh --build
# =============================================================================

# OpenAI API Key (optional) — Uncomment and set for real LLM responses
# OPENAI_API_KEY=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

# Anthropic API Key (optional) — Alternative LLM provider
# ANTHROPIC_API_KEY=sk-ant-your-key-here

# LLM Model (optional) — Defaults to gpt-4o
# LLM_MODEL=gpt-4o

# Thesys API Key (optional) — For generative UI features
# THESYS_API_KEY=sk-th-SPV4lcxZ3EljtyOHDOEUzTZT9VhRsSutagsltHyAJzOblOfB4FJqVxrqzQaDiUfZoRaxBwhEta3Q4K8MH5FbhtHhfl2EOU9d310w
