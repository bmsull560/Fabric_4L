# =============================================================================
# Value Fabric — Local Dev Environment
# =============================================================================
# Copy this file to .env.dev and optionally add your LLM API keys.
# No keys required — ValuePilot runs in heuristic mode by default.
#
# Usage:
#   cp .env.dev.example .env.dev
#   ./scripts/dev-up.sh --build
# =============================================================================

# OpenAI API Key (optional) — Uncomment and set for real LLM responses
# OPENAI_API_KEY=

# Anthropic API Key (optional) — Alternative LLM provider
# ANTHROPIC_API_KEY=sk-ant-your-key-here

# LLM Model (optional) — Defaults to gpt-4o
# LLM_MODEL=gpt-4o

# Thesys API Key (optional) — For generative UI features
# THESYS_API_KEY=

# DEV_AUTH_BYPASS=true

# Docker Base Image Override — uncomment to use the public image locally.
# Leave unset to use the Dockerfile default (private GHCR image).
BASE_IMAGE=python:3.11.11-slim-bookworm

# CORS origins — not required in development (services default to localhost dev servers).
# Set explicitly to override the default localhost:5173 / localhost:3000 fallback.
# CORS_ORIGINS=http://localhost:5173,http://localhost:3000