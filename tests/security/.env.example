# Security Test Environment Configuration
# Copy this file to .env and update with your test values

# =============================================================================
# Required: JWT Secret for Token Generation/Validation
# Must be at least 32 characters for HS256 security
# =============================================================================
JWT_SECRET=test-jwt-secret-must-be-at-least-32-characters-long-for-hs256

# =============================================================================
# Test Database (PostgreSQL)
# =============================================================================
TEST_DATABASE_URL=postgresql://localhost:5432/test_value_fabric
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=test_value_fabric

# =============================================================================
# Redis (for cache isolation tests)
# =============================================================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# =============================================================================
# Neo4j (for graph tenant isolation tests)
# =============================================================================
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=testpassword

# =============================================================================
# Test Environment Flag
# =============================================================================
ENVIRONMENT=test
CI=false
