{
  "version": "1.0",
  "skill": "semantic_search",
  "traces": [
    {
      "id": "ss-001",
      "description": "Predictive analytics query returns Capability entities with high similarity",
      "input": {
        "query": "predictive analytics for demand forecasting",
        "entity_types": ["Capability"],
        "top_k": 5,
        "similarity_threshold": 0.7
      },
      "assertions": {
        "min_results": 1,
        "all_type": "Capability",
        "min_similarity": 0.7
      }
    },
    {
      "id": "ss-002",
      "description": "Empty results for nonsense query",
      "input": {
        "query": "xyzzy irrelevant gibberish",
        "top_k": 3,
        "similarity_threshold": 0.95
      },
      "assertions": {
        "max_results": 0
      }
    },
    {
      "id": "ss-003",
      "description": "Multi-type search returns mixed entity types",
      "input": {
        "query": "reduce costs for supply chain operations",
        "entity_types": ["Capability", "ValueDriver"],
        "top_k": 10,
        "similarity_threshold": 0.6
      },
      "assertions": {
        "min_results": 1,
        "allowed_types": ["Capability", "ValueDriver"]
      }
    }
  ]
}
