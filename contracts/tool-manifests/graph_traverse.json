{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://valuefabric.ai/contracts/tool-manifests/graph_traverse.json",
  "name": "graph_traverse",
  "version": "1.0.0",
  "description": "Navigate the Knowledge Graph via relationships to find connected entities.",
  "parameters": {
    "type": "object",
    "properties": {
      "start_node_id": {
        "type": "string",
        "description": "Entity node ID to start traversal from.",
        "minLength": 1
      },
      "relationship_types": {
        "type": "array",
        "items": {
          "type": "string",
          "enum": ["ENABLES", "BENEFITS", "DRIVES", "CONTRIBUTES_TO"]
        },
        "description": "Relationship types to follow. Omit to follow all types."
      },
      "direction": {
        "type": "string",
        "enum": ["OUTGOING", "INCOMING", "BOTH"],
        "default": "BOTH",
        "description": "Direction of traversal relative to start node."
      },
      "depth": {
        "type": "integer",
        "minimum": 1,
        "maximum": 5,
        "default": 2,
        "description": "Maximum traversal depth."
      },
      "min_confidence": {
        "type": "number",
        "minimum": 0.0,
        "maximum": 1.0,
        "description": "Minimum relationship confidence score to include."
      }
    },
    "required": ["start_node_id"],
    "additionalProperties": false
  },
  "returns": {
    "type": "object",
    "properties": {
      "nodes": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "id": { "type": "string" },
            "type": { "type": "string" },
            "name": { "type": "string" },
            "description": { "type": "string" }
          },
          "required": ["id", "type", "name"]
        }
      },
      "relationships": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "from_id": { "type": "string" },
            "to_id": { "type": "string" },
            "type": { "type": "string" },
            "confidence": { "type": "number" },
            "evidence": { "type": "string" }
          },
          "required": ["from_id", "to_id", "type", "confidence"]
        }
      }
    },
    "required": ["nodes", "relationships"]
  }
}
