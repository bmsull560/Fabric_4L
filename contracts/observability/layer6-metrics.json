{
  "service": "layer6-benchmarks",
  "contract_version": 1,
  "metrics": [
    {
      "name": "layer6_requests_total",
      "type": "counter",
      "required": true,
      "description": "Count of benchmark API requests processed.",
      "labels": [
        "route",
        "method",
        "status_class"
      ],
      "max_cardinality": {
        "route": 20,
        "method": 8,
        "status_class": 5
      }
    },
    {
      "name": "layer6_request_duration_seconds",
      "type": "histogram",
      "required": true,
      "description": "Benchmark API request latency histogram.",
      "labels": [
        "route",
        "method"
      ],
      "max_cardinality": {
        "route": 20,
        "method": 8
      }
    },
    {
      "name": "layer6_dataset_comparisons_total",
      "type": "counter",
      "required": true,
      "description": "Count of compare operations by outcome.",
      "labels": [
        "industry",
        "outcome"
      ],
      "max_cardinality": {
        "industry": 50,
        "outcome": 4
      }
    },
    {
      "name": "layer6_health_status",
      "type": "gauge",
      "required": true,
      "description": "Service health gauge.",
      "labels": [
        "service"
      ],
      "max_cardinality": {
        "service": 5
      }
    }
  ]
}
