{
  "openapi": "3.1.0",
  "info": {
    "title": "Value Fabric \u2014 Layer 4: Agents",
    "description": "Agentic engine with LangGraph orchestration, workflow management, ROI/whitespace analysis, business case generation, and tool invocation.",
    "version": "1.0.0",
    "contact": {
      "name": "Value Fabric Team"
    }
  },
  "servers": [
    {
      "url": "/api/v1",
      "description": "Layer 4 Agents API"
    }
  ],
  "security": [
    {
      "BearerAuth": [],
      "TenantHeader": []
    }
  ],
  "paths": {
    "/workflows": {
      "post": {
        "operationId": "create_workflow",
        "summary": "Create Workflow",
        "description": "Create and start a new workflow instance.",
        "tags": [
          "Workflows"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/WorkflowCreateRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Workflow created successfully.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/WorkflowCreateResponse"
                }
              }
            }
          },
          "400": {
            "description": "Invalid request.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/workflows/active": {
      "get": {
        "operationId": "list_active_workflows",
        "summary": "List Active Workflows",
        "description": "Retrieve all currently active workflow instances.",
        "tags": [
          "Workflows"
        ],
        "responses": {
          "200": {
            "description": "List of active workflows.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/WorkflowStatusResponse"
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/workflows/{workflow_id}": {
      "get": {
        "operationId": "get_workflow_status",
        "summary": "Get Workflow Status",
        "description": "Retrieve the current status and details of a workflow instance.",
        "tags": [
          "Workflows"
        ],
        "parameters": [
          {
            "name": "workflow_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            },
            "description": "Unique identifier of the workflow instance."
          }
        ],
        "responses": {
          "200": {
            "description": "Workflow status retrieved.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/WorkflowStatusResponse"
                }
              }
            }
          },
          "404": {
            "description": "Workflow not found.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      },
      "delete": {
        "operationId": "delete_workflow",
        "summary": "Delete Workflow",
        "description": "Cancel and delete a workflow instance.",
        "tags": [
          "Workflows"
        ],
        "parameters": [
          {
            "name": "workflow_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            },
            "description": "Unique identifier of the workflow instance."
          }
        ],
        "responses": {
          "200": {
            "description": "Workflow deleted.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          },
          "404": {
            "description": "Workflow not found.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/workflows/{workflow_id}/events": {
      "get": {
        "operationId": "get_workflow_events",
        "summary": "Stream Workflow Events (SSE)",
        "description": "Stream real-time workflow events via Server-Sent Events.",
        "tags": [
          "Workflows"
        ],
        "parameters": [
          {
            "name": "workflow_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            },
            "description": "Unique identifier of the workflow instance."
          }
        ],
        "responses": {
          "200": {
            "description": "SSE event stream.",
            "content": {
              "text/event-stream": {
                "schema": {
                  "$ref": "#/components/schemas/WorkflowEvent"
                }
              }
            }
          },
          "404": {
            "description": "Workflow not found.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/workflows/{workflow_id}/result": {
      "get": {
        "operationId": "get_workflow_result",
        "summary": "Get Workflow Result",
        "description": "Retrieve the output / result of a completed workflow.",
        "tags": [
          "Workflows"
        ],
        "parameters": [
          {
            "name": "workflow_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            },
            "description": "Unique identifier of the workflow instance."
          }
        ],
        "responses": {
          "200": {
            "description": "Workflow result.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "workflow_instance_id": {
                      "type": "string",
                      "format": "uuid"
                    },
                    "status": {
                      "type": "string"
                    },
                    "results": {
                      "type": "object"
                    }
                  }
                }
              }
            }
          },
          "404": {
            "description": "Workflow not found.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/workflows/{workflow_id}/resume": {
      "post": {
        "operationId": "resume_workflow",
        "summary": "Resume Workflow",
        "description": "Resume a paused workflow instance.",
        "tags": [
          "Workflows"
        ],
        "parameters": [
          {
            "name": "workflow_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            },
            "description": "Unique identifier of the workflow instance."
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/WorkflowResumeRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Workflow resumed.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/WorkflowResumeResponse"
                }
              }
            }
          },
          "404": {
            "description": "Workflow not found.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/workflows/{workflow_id}/pause": {
      "post": {
        "operationId": "pause_workflow",
        "summary": "Pause Workflow",
        "description": "Pause a running workflow instance.",
        "tags": [
          "Workflows"
        ],
        "parameters": [
          {
            "name": "workflow_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            },
            "description": "Unique identifier of the workflow instance."
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/WorkflowPauseRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Workflow paused.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/WorkflowPauseResponse"
                }
              }
            }
          },
          "404": {
            "description": "Workflow not found.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/analysis/roi": {
      "post": {
        "operationId": "run_roi_analysis",
        "summary": "ROI Analysis",
        "description": "Run an ROI analysis for a prospect using specified value drivers.",
        "tags": [
          "Analysis"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ROIAnalysisRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "ROI analysis result.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ROIAnalysisResponse"
                }
              }
            }
          },
          "400": {
            "description": "Invalid request.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/analysis/whitespace": {
      "post": {
        "operationId": "run_whitespace_analysis",
        "summary": "Whitespace Analysis",
        "description": "Run a whitespace / gap analysis for a prospect.",
        "tags": [
          "Analysis"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/WhitespaceAnalysisRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Whitespace analysis result.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/WhitespaceAnalysisResponse"
                }
              }
            }
          },
          "400": {
            "description": "Invalid request.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/cases": {
      "post": {
        "operationId": "create_business_case",
        "summary": "Generate Business Case",
        "description": "Generate a business case document for a prospect.",
        "tags": [
          "Analysis"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/BusinessCaseRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Business case generated.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BusinessCaseResponse"
                }
              }
            }
          },
          "400": {
            "description": "Invalid request.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/tools": {
      "get": {
        "operationId": "list_tools",
        "summary": "List Tools",
        "description": "List all available agent tools.",
        "tags": [
          "Tools"
        ],
        "responses": {
          "200": {
            "description": "List of tools.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/ToolSummary"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/tools/categories": {
      "get": {
        "operationId": "list_tool_categories",
        "summary": "List Tool Categories",
        "description": "List all tool categories.",
        "tags": [
          "Tools"
        ],
        "responses": {
          "200": {
            "description": "List of tool categories.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/tools/{tool_name}": {
      "get": {
        "operationId": "get_tool",
        "summary": "Get Tool Details",
        "description": "Get the schema and metadata for a specific tool.",
        "tags": [
          "Tools"
        ],
        "parameters": [
          {
            "name": "tool_name",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Name of the tool."
          }
        ],
        "responses": {
          "200": {
            "description": "Tool details.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ToolDetail"
                }
              }
            }
          },
          "404": {
            "description": "Tool not found.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/tools/invoke": {
      "post": {
        "operationId": "invoke_tool",
        "summary": "Invoke Tool",
        "description": "Invoke a tool by name with the given parameters.",
        "tags": [
          "Tools"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ToolInvokeRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Tool invocation result.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ToolInvokeResponse"
                }
              }
            }
          },
          "400": {
            "description": "Invalid request.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "404": {
            "description": "Tool not found.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/c1/stream": {
      "post": {
        "operationId": "c1_stream",
        "summary": "C1 Proxy Stream",
        "description": "Stream agent responses via the C1 proxy (Server-Sent Events).",
        "tags": [
          "Integration"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "prompt": {
                    "type": "string",
                    "description": "User prompt to stream."
                  },
                  "context": {
                    "type": "object",
                    "description": "Additional context for the agent."
                  }
                },
                "required": [
                  "prompt"
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "SSE stream of agent responses.",
            "content": {
              "text/event-stream": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "event": {
                      "type": "string"
                    },
                    "data": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "BearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "description": "JWT token issued by the shared identity service."
      },
      "TenantHeader": {
        "type": "apiKey",
        "in": "header",
        "name": "X-Tenant-ID",
        "description": "UUID of the tenant. Required for data isolation and RBAC."
      }
    },
    "schemas": {
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": {
            "type": "object",
            "properties": {
              "code": {
                "type": "string",
                "description": "Machine-readable error code."
              },
              "message": {
                "type": "string",
                "description": "Human-readable error description."
              },
              "details": {
                "type": "object",
                "description": "Optional additional context."
              }
            },
            "required": [
              "code",
              "message"
            ]
          }
        },
        "required": [
          "error"
        ]
      },
      "WorkflowCreateRequest": {
        "type": "object",
        "properties": {
          "workflow_type": {
            "type": "string",
            "enum": [
              "roi_calculator",
              "whitespace_analysis",
              "business_case",
              "orchestrator"
            ],
            "description": "Type of workflow to execute."
          },
          "tenant_id": {
            "type": "string",
            "format": "uuid",
            "description": "Tenant identifier."
          },
          "user_id": {
            "type": "string",
            "format": "uuid",
            "description": "User who initiated the workflow."
          },
          "inputs": {
            "type": "object",
            "description": "Workflow-specific input parameters."
          },
          "priority": {
            "type": "string",
            "default": "NORMAL",
            "description": "Execution priority."
          }
        },
        "required": [
          "workflow_type",
          "tenant_id",
          "user_id",
          "inputs"
        ]
      },
      "WorkflowCreateResponse": {
        "type": "object",
        "properties": {
          "workflow_instance_id": {
            "type": "string",
            "format": "uuid",
            "description": "Unique identifier for the created workflow instance."
          },
          "status": {
            "type": "string",
            "description": "Current workflow status."
          },
          "estimated_duration_seconds": {
            "type": "integer",
            "description": "Estimated time to completion in seconds."
          }
        },
        "required": [
          "workflow_instance_id",
          "status",
          "estimated_duration_seconds"
        ]
      },
      "WorkflowStatusResponse": {
        "type": "object",
        "properties": {
          "workflow_instance_id": {
            "type": "string",
            "format": "uuid"
          },
          "workflow_type": {
            "type": "string",
            "enum": [
              "roi_calculator",
              "whitespace_analysis",
              "business_case",
              "orchestrator"
            ]
          },
          "status": {
            "type": "string"
          },
          "current_state": {
            "type": "string"
          },
          "current_node": {
            "type": "string"
          },
          "progress_percentage": {
            "type": "number",
            "minimum": 0,
            "maximum": 100,
            "description": "Completion percentage (0-100)."
          },
          "started_at": {
            "type": "string",
            "format": "date-time"
          },
          "completed_at": {
            "type": [
              "string",
              "null"
            ],
            "format": "date-time"
          },
          "error_count": {
            "type": "integer"
          },
          "has_output": {
            "type": "boolean"
          },
          "results": {
            "type": [
              "object",
              "null"
            ]
          },
          "tenant_id": {
            "type": "string",
            "format": "uuid"
          },
          "user_id": {
            "type": "string",
            "format": "uuid"
          },
          "priority": {
            "type": "string"
          },
          "scheduler_status": {
            "type": "string"
          }
        },
        "required": [
          "workflow_instance_id",
          "workflow_type",
          "status"
        ]
      },
      "WorkflowEvent": {
        "type": "object",
        "properties": {
          "event_id": {
            "type": "string",
            "format": "uuid"
          },
          "event_type": {
            "type": "string",
            "description": "Type of workflow event (e.g. state_change, error, completed)."
          },
          "timestamp": {
            "type": "string",
            "format": "date-time"
          },
          "message": {
            "type": "string"
          },
          "payload": {
            "type": [
              "object",
              "null"
            ],
            "description": "Optional event-specific data."
          }
        },
        "required": [
          "event_id",
          "event_type",
          "timestamp",
          "message"
        ]
      },
      "WorkflowResumeRequest": {
        "type": "object",
        "properties": {
          "user_id": {
            "type": "string",
            "format": "uuid",
            "description": "User requesting the resume."
          },
          "resume_data": {
            "type": [
              "object",
              "null"
            ],
            "description": "Optional data to provide to the workflow on resume."
          },
          "tenant_id": {
            "type": "string",
            "format": "uuid"
          }
        },
        "required": [
          "user_id"
        ]
      },
      "WorkflowResumeResponse": {
        "type": "object",
        "properties": {
          "workflow_instance_id": {
            "type": "string",
            "format": "uuid"
          },
          "status": {
            "type": "string"
          },
          "resumed_from_node": {
            "type": "string"
          },
          "message": {
            "type": "string"
          },
          "estimated_completion_seconds": {
            "type": "integer"
          }
        },
        "required": [
          "workflow_instance_id",
          "status",
          "resumed_from_node",
          "message"
        ]
      },
      "WorkflowPauseRequest": {
        "type": "object",
        "properties": {
          "user_id": {
            "type": "string",
            "format": "uuid",
            "description": "User requesting the pause."
          },
          "reason": {
            "type": "string",
            "description": "Optional reason for pausing."
          },
          "tenant_id": {
            "type": "string",
            "format": "uuid"
          }
        },
        "required": [
          "user_id"
        ]
      },
      "WorkflowPauseResponse": {
        "type": "object",
        "properties": {
          "workflow_instance_id": {
            "type": "string",
            "format": "uuid"
          },
          "status": {
            "type": "string"
          },
          "paused_at": {
            "type": "string",
            "format": "date-time"
          },
          "current_node": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        },
        "required": [
          "workflow_instance_id",
          "status",
          "paused_at",
          "current_node",
          "message"
        ]
      },
      "ROIAnalysisRequest": {
        "type": "object",
        "properties": {
          "prospect_id": {
            "type": "string",
            "format": "uuid",
            "description": "Identifier of the prospect."
          },
          "value_driver_ids": {
            "type": "array",
            "items": {
              "type": "string",
              "format": "uuid"
            },
            "description": "List of value driver IDs to include in the analysis."
          },
          "prospect_data": {
            "type": "object",
            "description": "Prospect-specific data for the ROI calculation."
          },
