  "components": {
    "schemas": {
      "ExtractAndIngestResponse": {
        "properties": {
          "job_id": {
            "type": "string",
            "title": "Job Id"
          },
          "overall_status": {
            "type": "string",
            "title": "Overall Status"
          },
          "extraction_status": {
            "type": "string",
            "title": "Extraction Status"
          },
          "ingestion_status": {
            "type": "string",
            "title": "Ingestion Status"
          },
          "message": {
            "type": "string",
            "title": "Message"
          }
        },
        "type": "object",
        "required": [
          "job_id",
          "overall_status",
          "extraction_status",
          "ingestion_status",
          "message"
        ],
        "title": "ExtractAndIngestResponse",
        "description": "Response for combined extract-and-ingest endpoint."
      },
      "ExtractRequest": {
        "properties": {
          "content_id": {
            "type": "string",
            "title": "Content Id",
            "description": "ID of content to extract from (from Layer 1)"
          },
          "source_url": {
            "type": "string",
            "title": "Source Url",
            "description": "URL of source document"
          },
          "markdown_content": {
            "type": "string",
            "title": "Markdown Content",
            "description": "Markdown content to extract from"
          },
          "extraction_config": {
            "additionalProperties": true,
            "type": "object",
            "title": "Extraction Config"
          }
        },
        "type": "object",
        "required": [
          "content_id",
          "source_url",
          "markdown_content"
        ],
        "title": "ExtractRequest",
        "description": "Request body for extraction endpoint."
      },
      "ExtractResponse": {
        "properties": {
          "extraction_job_id": {
            "type": "string",
            "title": "Extraction Job Id"
          },
          "status": {
            "type": "string",
            "title": "Status"
          },
          "message": {
            "type": "string",
            "title": "Message"
          }
        },
        "type": "object",
        "required": [
          "extraction_job_id",
          "status",
          "message"
        ],
        "title": "ExtractResponse",
        "description": "Response from extraction endpoint."
      },
      "ExtractionStatusResponse": {
        "properties": {
          "job_id": {
            "type": "string",
            "title": "Job Id"
          },
          "overall_status": {
            "type": "string",
            "title": "Overall Status"
          },
          "extraction_status": {
            "type": "string",
            "title": "Extraction Status"
          },
          "ingestion_status": {
            "type": "string",
            "title": "Ingestion Status"
          },
          "entities_extracted": {
            "type": "integer",
            "title": "Entities Extracted"
          },
          "relationships_extracted": {
            "type": "integer",
            "title": "Relationships Extracted"
          },
          "retry_count": {
            "type": "integer",
            "title": "Retry Count",
            "default": 0
          },
          "last_error": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Last Error"
          },
          "next_retry_at": {
            "anyOf": [
              {
                "type": "string",
                "format": "date-time"
              },
              {
                "type": "null"
              }
            ],
            "title": "Next Retry At"
          },
          "started_at": {
            "type": "string",
            "format": "date-time",
            "title": "Started At"
          },
          "completed_at": {
            "anyOf": [
              {
                "type": "string",
                "format": "date-time"
              },
              {
                "type": "null"
              }
            ],
            "title": "Completed At"
          }
        },
        "type": "object",
        "required": [
          "job_id",
          "overall_status",
          "extraction_status",
          "ingestion_status",
          "entities_extracted",
          "relationships_extracted",
          "started_at",
          "completed_at"
        ],
        "title": "ExtractionStatusResponse",
        "description": "Status of a combined extraction + ingestion pipeline job."
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "type": "array",
            "title": "Detail"
          }
        },
        "type": "object",
        "title": "HTTPValidationError"
      },
      "ProvenanceResponse": {
        "properties": {
          "activity_id": {
            "type": "string",
            "title": "Activity Id"
          },
          "source": {
            "additionalProperties": true,
            "type": "object",
            "title": "Source"
          },
          "extraction": {
            "additionalProperties": true,
            "type": "object",
            "title": "Extraction"
          },
          "steps": {
            "items": {
              "additionalProperties": true,
              "type": "object"
            },
            "type": "array",
            "title": "Steps"
          },
          "output": {
            "additionalProperties": true,
            "type": "object",
            "title": "Output"
          }
        },
        "type": "object",
        "required": [
          "activity_id",
          "source",
          "extraction",
          "steps",
          "output"
        ],
        "title": "ProvenanceResponse",
        "description": "Provenance chain for an entity or output."
      },
      "ValidationError": {
        "properties": {
          "loc": {
            "items": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            },
            "type": "array",
            "title": "Location"
          },
          "msg": {
            "type": "string",
            "title": "Message"
          },
          "type": {
            "type": "string",
            "title": "Error Type"
          },
          "input": {
            "title": "Input"
          },
          "ctx": {
            "type": "object",
            "title": "Context"
          }
        },
        "type": "object",
        "required": [
          "loc",
          "msg",
          "type"
        ],
        "title": "ValidationError"
      }
    }
  }
}