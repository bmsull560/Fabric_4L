{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://valuefabric.dev/contracts/jsonschema/workflows/common.json",
  "title": "Workflow Common Contracts",
  "$defs": {
    "WorkflowStatus": {
      "type": "string",
      "enum": ["pending", "running", "paused", "interrupted", "completed", "failed", "cancelled"]
    },
    "PaginationEnvelope": {
      "type": "object",
      "required": ["items", "total", "limit", "offset", "has_more"],
      "properties": {
        "items": {"type": "array"},
        "total": {"type": "integer", "minimum": 0},
        "limit": {"type": "integer", "minimum": 1},
        "offset": {"type": "integer", "minimum": 0},
        "has_more": {"type": "boolean"}
      },
      "additionalProperties": false
    }
  }
}
