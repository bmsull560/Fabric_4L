{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://valuefabric/contracts/jsonschema/system-route-health.json",
  "title": "SystemRouteHealthResponse",
  "type": "object",
  "required": ["status", "service", "readiness"],
  "properties": {
    "status": {
      "type": "string",
      "enum": ["healthy", "degraded", "unhealthy"]
    },
    "service": {
      "type": "string",
      "minLength": 1
    },
    "readiness": {
      "type": "object",
      "required": ["is_ready", "reason"],
      "properties": {
        "is_ready": {"type": "boolean"},
        "reason": {"type": "string"}
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
