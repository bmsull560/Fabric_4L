{
  "$schema": "../schemas/workflow.schema.json",
  "version": "1.0.0",
  "kind": "workflow",
  "owner": "@layer4-agents",
  "risk_class": "high",
  "compatibility": {
    "supported_prior_versions": [],
    "migration_notes": "Initial workflow state-machine registry entry derived from services/layer4-agents/src/models/workflow_config.py."
  },
  "observability": {
    "required_trace_fields": [
      "tenant_id",
      "trace_id",
      "workflow_id",
      "workflow_type",
      "state"
    ],
    "required_metrics": [
      "workflow_transition_total",
      "workflow_duration_ms",
      "workflow_error_total"
    ],
    "audit_events": [
      "workflow_started",
      "workflow_transitioned",
      "workflow_completed",
      "workflow_failed"
    ]
  },
  "governance": {
    "review_requirement": "Contract Council review for state, transition, invariant, or tool/prompt binding changes.",
    "approval_threshold": "Two reviewers representing Layer 4 and Platform Contracts.",
    "rollout_policy": "CI warning mode first; runtime transition enforcement is feature-flagged.",
    "deprecation_policy": "Maintain prior workflow version until in-flight checkpoints can be migrated or expired."
  },
  "id": "workflow-business-case",
  "workflow_type": "business_case",
  "source_path": "../../../services/layer4-agents/src/workflows/business_case.py",
  "description": "Generates comprehensive business case documents.",
  "entry_point": "gather_inputs",
  "states": [
    "gather_inputs",
    "run_roi",
    "verify_truth_requirements",
    "generate_narrative",
    "assemble",
    "end"
  ],
  "transitions": [
    {
      "source": "gather_inputs",
      "target": "run_roi"
    },
    {
      "source": "run_roi",
      "target": "verify_truth_requirements"
    },
    {
      "source": "verify_truth_requirements",
      "target": "generate_narrative"
    },
    {
      "source": "generate_narrative",
      "target": "assemble"
    },
    {
      "source": "assemble",
      "target": "end"
    }
  ],
  "invariants": [
    "tenant context is present",
    "truth requirements are verified before narrative generation",
    "financial claims include truth references"
  ]
}
