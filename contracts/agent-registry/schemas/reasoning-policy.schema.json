{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://valuefabric.ai/contracts/agent-registry/schemas/reasoning-policy.schema.json",
  "title": "Fabric 4L Reasoning Policy Contract",
  "allOf": [
    {
      "$ref": "./base-contract.schema.json"
    }
  ],
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "kind": {
      "const": "reasoning_policy"
    },
    "owner": {
      "type": "string",
      "minLength": 1
    },
    "risk_class": {
      "type": "string",
      "enum": [
        "low",
        "medium",
        "high",
        "regulated"
      ]
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "compatibility": {
      "type": "object"
    },
    "observability": {
      "type": "object"
    },
    "governance": {
      "type": "object"
    },
    "confidence_thresholds": {
      "type": "object"
    },
    "evidence_requirements": {
      "type": "array"
    },
    "explanation_requirements": {
      "type": "array"
    },
    "escalation_rules": {
      "type": "array"
    },
    "allowed_tool_classes": {
      "type": "array"
    }
  },
  "required": [
    "id",
    "version",
    "kind",
    "owner",
    "risk_class",
    "description",
    "compatibility",
    "observability",
    "governance",
    "confidence_thresholds",
    "evidence_requirements",
    "explanation_requirements",
    "escalation_rules",
    "allowed_tool_classes"
  ]
}
