{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://valuefabric.ai/contracts/agent-registry/schemas/tool-registry.schema.json",
  "title": "Fabric 4L Agent Tool Registry",
  "allOf": [
    {
      "$ref": "./base-contract.schema.json"
    }
  ],
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "kind": {
      "const": "tool"
    },
    "owner": {
      "type": "string",
      "minLength": 1
    },
    "risk_class": {
      "type": "string",
      "enum": [
        "low",
        "medium",
        "high",
        "regulated"
      ]
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "compatibility": {
      "type": "object"
    },
    "observability": {
      "type": "object"
    },
    "governance": {
      "type": "object"
    },
    "tools": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "version": {
            "type": "string",
            "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
          },
          "manifest_path": {
            "type": "string",
            "minLength": 1
          },
          "input_schema": {
            "type": "object"
          },
          "output_schema": {
            "type": "object"
          },
          "side_effect_class": {
            "type": "string",
            "enum": [
              "read_only",
              "write",
              "external_notification",
              "export",
              "administrative"
            ]
          },
          "timeout_budget_ms": {
            "type": "integer",
            "minimum": 1000
          },
          "tenant_required": {
            "type": "boolean"
          },
          "provenance": {
            "type": "object"
          },
          "error_schema": {
            "type": "object"
          }
        },
        "required": [
          "name",
          "version",
          "manifest_path",
          "input_schema",
          "output_schema",
          "side_effect_class",
          "timeout_budget_ms",
          "tenant_required",
          "provenance",
          "error_schema"
        ]
      }
    }
  },
  "required": [
    "id",
    "version",
    "kind",
    "owner",
    "risk_class",
    "description",
    "compatibility",
    "observability",
    "governance",
    "tools"
  ]
}
