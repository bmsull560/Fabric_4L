{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://valuefabric.ai/contracts/agent-registry/schemas/semantic-compatibility.schema.json",
  "title": "Fabric 4L Agent Semantic Compatibility Matrix",
  "type": "object",
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
    "agent_registry_version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
    "min_runtime_version": { "type": "string", "minLength": 1 },
    "enforcement_default": { "type": "string", "enum": ["warn", "strict"] },
    "compatible_event_versions": {
      "type": "object",
      "additionalProperties": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" }
    },
    "agent_contracts": {
      "type": "object",
      "additionalProperties": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" }
    },
    "prompt_contracts": {
      "type": "object",
      "additionalProperties": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" }
    },
    "tool_contracts": {
      "type": "object",
      "additionalProperties": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" }
    },
    "workflow_contracts": {
      "type": "object",
      "additionalProperties": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" }
    },
    "memory_contracts": {
      "type": "object",
      "additionalProperties": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" }
    },
    "deprecated_contracts": {
      "type": "array",
      "items": { "type": "string" }
    },
    "notes": { "type": "string" }
  },
  "required": [
    "id",
    "version",
    "agent_registry_version",
    "min_runtime_version",
    "enforcement_default",
    "compatible_event_versions",
    "agent_contracts",
    "prompt_contracts",
    "tool_contracts",
    "workflow_contracts",
    "memory_contracts",
    "deprecated_contracts"
  ]
}
