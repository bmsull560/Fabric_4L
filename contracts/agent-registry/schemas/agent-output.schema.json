{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://valuefabric.ai/contracts/agent-registry/schemas/agent-output.schema.json",
  "title": "Fabric 4L Agent Output Registry",
  "allOf": [
    {
      "$ref": "./base-contract.schema.json"
    }
  ],
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "kind": {
      "const": "agent_output"
    },
    "owner": {
      "type": "string",
      "minLength": 1
    },
    "risk_class": {
      "type": "string",
      "enum": [
        "low",
        "medium",
        "high",
        "regulated"
      ]
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "compatibility": {
      "type": "object"
    },
    "observability": {
      "type": "object"
    },
    "governance": {
      "type": "object"
    },
    "agents": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "agent_type",
          "source_path",
          "capabilities",
          "decision_envelope"
        ]
      }
    }
  },
  "required": [
    "id",
    "version",
    "kind",
    "owner",
    "risk_class",
    "description",
    "compatibility",
    "observability",
    "governance",
    "agents"
  ]
}
