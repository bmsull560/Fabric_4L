{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://valuefabric.ai/contracts/agent-registry/schemas/prompt.schema.json",
  "title": "Fabric 4L Prompt Metadata Contract",
  "allOf": [
    {
      "$ref": "./base-contract.schema.json"
    }
  ],
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "kind": {
      "const": "prompt"
    },
    "owner": {
      "type": "string",
      "minLength": 1
    },
    "risk_class": {
      "type": "string",
      "enum": [
        "low",
        "medium",
        "high",
        "regulated"
      ]
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "compatibility": {
      "type": "object"
    },
    "observability": {
      "type": "object"
    },
    "governance": {
      "type": "object"
    },
    "prompt_path": {
      "type": "string"
    },
    "inputs": {
      "type": "array"
    },
    "outputs": {
      "type": "array"
    },
    "reasoning_policy": {
      "type": "string"
    },
    "changelog": {
      "type": "array"
    }
  },
  "required": [
    "id",
    "version",
    "kind",
    "owner",
    "risk_class",
    "description",
    "compatibility",
    "observability",
    "governance",
    "prompt_path",
    "inputs",
    "outputs",
    "reasoning_policy",
    "changelog"
  ]
}
