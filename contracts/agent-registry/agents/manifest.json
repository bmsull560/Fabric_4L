{
  "$schema": "../schemas/agent-output.schema.json",
  "id": "layer4-agent-output-registry",
  "version": "1.0.0",
  "kind": "agent_output",
  "owner": "@layer4-agents",
  "risk_class": "high",
  "description": "Registry of production Layer 4 agent output envelopes and capabilities used to detect untracked behavior drift.",
  "agents": [
    {
      "agent_type": "ContextExtractionAgent",
      "source_path": "services/layer4-agents/src/agents/taxonomy.py",
      "capabilities": [
        "extract_profile",
        "extract_stakeholders",
        "extract_pain_points",
        "extract_financials",
        "extract_risk_factors"
      ],
      "decision_envelope": {
        "input_schema": {
          "type": "object",
          "required": [
            "capability",
            "parameters"
          ]
        },
        "output_schema": {
          "type": "object",
          "expected_fields": [
            "profile",
            "confidence",
            "stakeholders",
            "pain_points",
            "categories",
            "risks"
          ]
        },
        "required_context_fields": [
          "tenant_id",
          "trace_id"
        ],
        "error_schema": {
          "$ref": "../schemas/tool-error.schema.json"
        }
      }
    },
    {
      "agent_type": "ValueModelAgent",
      "source_path": "services/layer4-agents/src/agents/taxonomy.py",
      "capabilities": [
        "build_value_tree",
