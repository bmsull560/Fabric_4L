  ],
  "compatibility": {
    "supported_prior_versions": [],
    "migration_notes": "Initial registry captures the canonical nine-agent taxonomy. Deprecated aliases remain import-compatible but are intentionally excluded from production registry coverage."
  },
  "observability": {
    "required_trace_fields": [
      "tenant_id",
      "trace_id",
      "agent_id",
      "agent_type",
      "capability"
    ],
    "required_metrics": [
      "agent_run_total",
      "agent_run_latency_ms",
      "agent_error_total"
    ],
    "audit_events": [
      "agent_started",
      "agent_completed",
      "agent_failed"
    ]
  },
  "governance": {
    "review_requirement": "Contract Council review for added or removed production agent types, capabilities, or output fields.",
    "approval_threshold": "Two reviewers representing Layer 4 and Platform Contracts.",
    "rollout_policy": "Registry validation runs in warning mode before runtime enforcement is enabled.",
    "deprecation_policy": "Deprecated aliases must be documented and kept out of production registry coverage unless reactivated."
  }
}
