{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "NarrativeBuilderOutput",
  "description": "Final output contract for the Narrative Builder service",
  "type": "object",
  "required": ["account_name", "executive_summary", "value_narrative", "risk_narrative", "confidence"],
  "properties": {
    "account_name": { "type": "string" },
    "executive_summary": {
      "type": "object",
      "required": ["executive_summary", "primary_value_proposition", "top_outcomes", "recommended_next_step", "confidence"],
      "properties": {
        "executive_summary": { "type": "string" },
        "primary_value_proposition": { "type": "string" },
        "top_outcomes": { "type": "array", "items": { "type": "string" } },
        "recommended_next_step": { "type": "string" },
        "confidence": { "type": "number", "minimum": 0.0, "maximum": 1.0 }
      }
    },
    "value_narrative": {
      "type": "object",
      "required": ["value_narrative", "primary_problem", "quantified_outcomes", "confidence"],
      "properties": {
        "value_narrative": { "type": "string" },
        "primary_problem": { "type": "string" },
        "quantified_outcomes": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["outcome", "value"],
            "properties": {
              "outcome": { "type": "string" },
              "value": { "type": "string" },
              "evidence_ref": { "type": "string" }
            }
          }
        },
        "expansion_opportunities": { "type": "array", "items": { "type": "string" } },
        "confidence": { "type": "number", "minimum": 0.0, "maximum": 1.0 }
      }
    },
    "risk_narrative": {
      "type": "object",
      "required": ["risk_narrative", "risks", "overall_risk_level", "confidence"],
      "properties": {
        "risk_narrative": { "type": "string" },
        "risks": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["risk", "impact", "mitigation", "severity"],
            "properties": {
              "risk": { "type": "string" },
              "impact": { "type": "string" },
              "mitigation": { "type": "string" },
              "severity": { "type": "string", "enum": ["high", "medium", "low"] }
            }
          }
        },
        "overall_risk_level": { "type": "string", "enum": ["high", "medium", "low"] },
        "confidence": { "type": "number", "minimum": 0.0, "maximum": 1.0 }
      }
    },
    "confidence": { "type": "number", "minimum": 0.0, "maximum": 1.0 },
    "llm_enrichment": { "type": "boolean" },
    "customer_facing_allowed": { "type": "boolean" },
    "human_review_required": { "type": "boolean" }
  }
}
