# Layer 4 Agents Service — local environment template
# Copy to .env and fill real values. Never commit secrets.
# See docs/how-to-guides/configure-sso.md for OIDC setup instructions.

# ============================================
# Runtime
# ============================================
ENVIRONMENT=development
AUTH_REQUIRED=true

# ============================================
# Database / Redis
# ============================================
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/layer4
# Harness persistence uses the same DATABASE_URL as the rest of Layer 4.
# No additional configuration required. Run migration 031 to create harness tables.
REDIS_URL=redis://localhost:6379/0

# ============================================
# Internal JWT (service-to-service and session cookies)
# ============================================
# Required in all environments — no runtime fallback.
JWT_SECRET=
JWT_ISSUER=value-fabric-internal
JWT_AUDIENCE=value-fabric-services

# ============================================
# OIDC / Keycloak Configuration
# ============================================
# Required for OIDC SSO flows. All three vars must be set together.
# See docs/how-to-guides/configure-sso.md for full setup instructions.
#
# JWKS resolution order (first match wins):
#   1. OIDC_JWKS_JSON  — static JSON string (air-gapped / test environments)
#   2. OIDC_JWKS_URL   — explicit URL (any OIDC provider)
#   3. Auto-built from KEYCLOAK_URL + KEYCLOAK_REALM (Keycloak only)
#
# Option A: explicit JWKS URL (works with any OIDC provider)
# Requires a running Keycloak instance. Leave commented for pure internal-JWT
# development (no Keycloak). Uncomment and set all three together.
# OIDC_ISSUER=http://localhost:8080/realms/fabric
# OIDC_AUDIENCE=fabric-api
# OIDC_JWKS_URL=http://localhost:8080/realms/fabric/protocol/openid-connect/certs

# Option B: Keycloak auto-URL construction (used when OIDC_JWKS_URL is unset)
# Builds: {KEYCLOAK_URL}/realms/{KEYCLOAK_REALM}/protocol/openid-connect/certs
# KEYCLOAK_URL=http://localhost:8080
# KEYCLOAK_REALM=fabric

# Option C: static JWKS JSON (useful for testing or air-gapped environments)
# OIDC_JWKS_JSON={"keys":[...]}

# ============================================
# Service-to-service auth
# ============================================
SERVICE_AUTH_SECRET=
API_KEY_HMAC_SECRET=

# ============================================
# LLM providers (optional — only needed for agent workflows)
# ============================================
OPENAI_API_KEY=
# THESYS_API_KEY=

# ============================================
# Inter-layer integration
# ============================================
# Layer 1 (Ingestion)
LAYER1_BASE_URL=http://localhost:8001
# LAYER1_API_KEY=

# Layer 2 (Extraction)
LAYER2_BASE_URL=http://localhost:8002
# LAYER2_API_KEY=

# Layer 3 (Knowledge Graph)
LAYER3_BASE_URL=http://localhost:8003
# LAYER3_API_KEY=
