# Layer 6 Benchmark Service local environment template
ENVIRONMENT=development
APP_ENV=development
TESTING=false
AUTH_REQUIRED=true

PORT=8006
API_PORT=8006
API_HOST=0.0.0.0
LOG_LEVEL=INFO
LAYER6_SERVICE_NAME=layer6-benchmarks
LAYER6_VERSION=dev
LAYER6_BUILD_SHA=unknown

DATABASE_URL=postgresql+asyncpg://layer6_app:change_me@localhost:5432/benchmarks
DATABASE_URL_SYNC=postgresql+psycopg2://layer6_app:change_me@localhost:5432/benchmarks
DB_HOST=localhost
DB_PORT=5432
DB_NAME=benchmarks
DB_USER=layer6_app
DB_PASSWORD=change_me

NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=change_me
NEO4J_DATABASE=neo4j
NEO4J_MAX_POOL_SIZE=50

JWT_SECRET=
API_KEY_HMAC_SECRET=
SERVICE_AUTH_SECRET=
LAYER3_API_KEY=
LAYER5_API_KEY=

ALLOW_INSECURE_DEV_AUTH_BYPASS=false
DEV_AUTH_BYPASS=false
AUTH_BYPASS_ENABLED=false
JWT_FALLBACK_TO_QUERY_PARAM=false
ALLOW_EPHEMERAL_ENCRYPTION=false
ALLOW_DEV_AUTH_BYPASS=
