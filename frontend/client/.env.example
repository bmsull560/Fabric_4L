# Value Fabric Frontend Environment Variables

# ============================================
# API Configuration
# ============================================
# Base API path for all backend layers
VITE_API_BASE=/api/v1

# Layer-specific prefixes (optional - defaults shown)
VITE_L1_PREFIX=/ingest
VITE_L2_PREFIX=/extract
VITE_L3_PREFIX=/graph
VITE_L4_PREFIX=/agents
VITE_L5_PREFIX=/truths

# ============================================
# Thesys C1 Generative UI Integration
# ============================================
# Enable interactive AI-powered business case exploration.
# The API key is kept server-side (THESYS_API_KEY env var on L4).
# The frontend only needs the feature flag below.
VITE_ENABLE_C1_REPORTS=false

# ============================================
# Development / Testing
# ============================================
# Enable mock API responses (useful for frontend development without backend)
VITE_USE_MOCKS=false
