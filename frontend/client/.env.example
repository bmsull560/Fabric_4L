# Value Fabric Frontend Environment Variables

# ============================================
# API Configuration
# ============================================
# Base API path for all backend layers
# Note: Backend OpenAPI routes include /v1 prefix (e.g., /v1/graph/subgraph)
# Layer prefixes below must include /v1 to align with backend routes
VITE_API_BASE=/api

# Layer-specific prefixes (must include /v1 to match backend OpenAPI routes)
VITE_L1_PREFIX=/v1/ingest
VITE_L2_PREFIX=/v1/extract
VITE_L3_PREFIX=/v1/graph
VITE_L4_PREFIX=/v1/agents
VITE_L5_PREFIX=/v1/truths
VITE_L6_PREFIX=/v1/benchmarks

# ============================================
# CRM Integration
# ============================================
# Enable CRM sync features (Salesforce, HubSpot, etc.)
VITE_ENABLE_CRM_SYNC=false
# Default CRM provider (salesforce, hubspot, pipedrive, zoho)
VITE_CRM_PROVIDER=salesforce
# CRM API endpoint (server-side proxy)
VITE_CRM_API_PROXY=/api/crm

# ============================================
# Thesys C1 Generative UI Integration
# ============================================
# Enable interactive AI-powered business case exploration.
# The API key is kept server-side (THESYS_API_KEY env var on L4).
# The frontend only needs the feature flag below.
VITE_ENABLE_C1_REPORTS=false

# ============================================
# Development / Testing
# ============================================
# Enable mock API responses (useful for frontend development without backend)
VITE_USE_MOCKS=false
