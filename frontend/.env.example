# Value Fabric — Frontend Environment Variables (all environments)
# This file defines the full contract. Copy to .env.local for overrides.
# No secrets belong here — only VITE_* public config.

# =============================================================================
# API Configuration (Class C — public)
# =============================================================================
VITE_API_BASE=/api/v1
VITE_L1_PREFIX=/ingest
VITE_L2_PREFIX=/extract
VITE_L3_PREFIX=/graph
VITE_L4_PREFIX=/agents
VITE_L5_PREFIX=/truths

# =============================================================================
# Feature Flags (Class C — public)
# =============================================================================
VITE_USE_MOCKS=false
VITE_ENABLE_SSE=true
VITE_ENABLE_MOCK_FALLBACK=false
VITE_ENABLE_CRM_SYNC=false
VITE_CRM_PROVIDER=salesforce
VITE_CRM_API_PROXY=/api/crm
VITE_ENABLE_C1_REPORTS=false

# =============================================================================
# Debug & Development (Class C — public)
# =============================================================================
VITE_ENABLE_QUERY_DEVTOOLS=false
VITE_API_LOG_LEVEL=error

