# =============================================================================
# Value Fabric — Test Environment
# =============================================================================
# Copy this file to .env.test for running E2E, contract, and backend-integrated tests.
# No real API keys required — tests run with deterministic seed data.
#
# Usage:
#   cp .env.test.example .env.test
#   docker compose -f docker-compose.e2e.yml up -d --wait
# =============================================================================

# =============================================================================
# Infrastructure Secrets — Test-only defaults. NEVER use in production.
# =============================================================================
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
NEO4J_AUTH=neo4j/devpassword
NEO4J_PASSWORD=devpassword

# =============================================================================
# Auth Secrets — Test-only defaults. NEVER use in production.
# =============================================================================
JWT_SECRET=e2e-test-secret-do-not-use-in-production-minimum-32-chars

# =============================================================================
# Service Database URLs — Test-only defaults. NEVER use in production.
# =============================================================================
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/layer4_agents
CHECKPOINT_DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/ground_truth
LAYER1_DATABASE_URL=postgresql://postgres:postgres@postgres:5432/ingestion
LAYER2_DATABASE_URL=postgresql://postgres:postgres@postgres:5432/layer2_extraction
