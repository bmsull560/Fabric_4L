# Example environment file - copy to .env/.env.dev and fill real values
DATABASE_URL=
REDIS_URL=redis://localhost:6379/0
# Required for all environments (including local/test). No runtime fallback.
JWT_SECRET=
JWT_ISSUER=value-fabric-internal
JWT_AUDIENCE=value-fabric-services
API_KEY_HMAC_SECRET=
SERVICE_AUTH_SECRET=
OPENAI_API_KEY=
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=
ENVIRONMENT=development
TESTING=false
AUTH_REQUIRED=true
# Override the default private GHCR base image for local development.
# Leave unset to use the Dockerfile default (private GHCR image).
BASE_IMAGE=python:3.11.11-slim-bookworm
# Required in all non-development environments.
# Comma-separated list of exact allowed origins; wildcards are not permitted.
# Example: CORS_ORIGINS=https://app.example.com,https://admin.example.com
CORS_ORIGINS=

# ============================================
# OIDC / Keycloak Configuration
# ============================================
# For Keycloak (recommended for production):
#   OIDC_ISSUER=https://auth.example.com/realms/fabric
#   OIDC_AUDIENCE=fabric-api
#   OIDC_JWKS_URL=https://auth.example.com/realms/fabric/protocol/openid-connect/certs
#
# For static JWKS (alternative):
#   OIDC_JWKS_JSON={"keys":[...]}
#
# For generic OIDC providers (Google, Auth0, Okta):
#   OIDC_ISSUER=https://accounts.google.com
#   OIDC_AUDIENCE=your-client-id
#   OIDC_JWKS_URL=https://www.googleapis.com/oauth2/v3/certs

# OIDC_ISSUER=
# OIDC_AUDIENCE=
# OIDC_JWKS_URL=
# OIDC_JWKS_JSON=
# Optional: OAuth callback state-signing secret override for Layer 4 integrations.
# If unset, JWT_SECRET is used. In staging/production set this via Infisical/Vault
# (or ExternalSecrets), never in committed files.
# SALESFORCE_OAUTH_STATE_SECRET=
#
# Keycloak-specific: used to auto-construct the JWKS URL when OIDC_JWKS_URL is
# not set. The constructed URL is: {KEYCLOAK_URL}/realms/{KEYCLOAK_REALM}/protocol/openid-connect/certs
# Override with your production Keycloak URL in non-development environments.
KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_REALM=fabric
# Layer 5 -> Layer 3 integration (Knowledge Graph service)
# Layer 2.5 — Signal Refinery (port 8007)
LAYER2_5_BASE_URL=http://localhost:8007
VITE_LAYER2_5_ROUTE_PREFIX=/signals

LAYER3_BASE_URL=http://localhost:8003
# Set to the in-cluster Layer 3 DNS name in deployment, for example:
# LAYER3_BASE_URL=http://layer3-knowledge:8003
# Set when Layer 3 requires auth between services
LAYER3_API_KEY=
# Per-request timeout for Layer 5 to Layer 3 sync calls.
# Production note: retries are code-managed for transient timeout/5xx failures
# with exponential backoff (1s, 2s) before the final attempt.
LAYER3_TIMEOUT_SECONDS=30
