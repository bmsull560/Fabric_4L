# Example environment file - copy to .env/.env.dev and fill real values
DATABASE_URL=
REDIS_URL=redis://localhost:6379/0
# Required for all environments (including local/test). No runtime fallback.
JWT_SECRET=
JWT_ISSUER=value-fabric-internal
JWT_AUDIENCE=value-fabric-services
API_KEY_HMAC_SECRET=
SERVICE_AUTH_SECRET=
OPENAI_API_KEY=
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=
ENVIRONMENT=development
TESTING=false
AUTH_REQUIRED=true
# Override the default private GHCR base image for local development.
# Leave unset to use the Dockerfile default (private GHCR image).
BASE_IMAGE=python:3.11.11-slim-bookworm
# Required in all non-development environments.
# Comma-separated list of exact allowed origins; wildcards are not permitted.
# Example: CORS_ORIGINS=https://app.example.com,https://admin.example.com
CORS_ORIGINS=

# ============================================
# OIDC / Keycloak Configuration
# ============================================
# For Keycloak (recommended for production):
#   OIDC_ISSUER=https://auth.example.com/realms/fabric
#   OIDC_AUDIENCE=fabric-api
#   OIDC_JWKS_URL=https://auth.example.com/realms/fabric/protocol/openid-connect/certs
#
# For static JWKS (alternative):
#   OIDC_JWKS_JSON={"keys":[...]}
#
# For generic OIDC providers (Google, Auth0, Okta):
#   OIDC_ISSUER=https://accounts.google.com
#   OIDC_AUDIENCE=your-client-id
#   OIDC_JWKS_URL=https://www.googleapis.com/oauth2/v3/certs

# OIDC_ISSUER=
# OIDC_AUDIENCE=
# OIDC_JWKS_URL=
# OIDC_JWKS_JSON=

# Layer 5 -> Layer 3 integration (Knowledge Graph service)
LAYER3_BASE_URL=http://localhost:8003
# Set when Layer 3 requires auth between services
LAYER3_API_KEY=
# Request timeout for Layer 5 to Layer 3 sync calls
LAYER3_TIMEOUT_SECONDS=30
