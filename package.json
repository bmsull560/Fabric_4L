{
  "name": "fabric-4l-monorepo",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "license": "MIT",
  "scripts": {
    "generate:contracts": "python scripts/ci/contract_compliance_gate.py --mode full --refresh-only",
    "generate:api": "pnpm --filter ./apps/web run generate:types",
    "check:contract-compliance": "python scripts/ci/contract_compliance_gate.py --mode full",
    "check:api-types": "pnpm run generate:api && git diff --exit-code apps/web/src/api/generated",
    "lint": "python scripts/ci/run_root_aggregate_checks.py lint",
    "test": "python scripts/ci/run_root_aggregate_checks.py test",
    "typecheck": "python scripts/ci/run_root_aggregate_checks.py typecheck",
    "check:default-scope": "node scripts/ci/check_default_scope.mjs",
    "preinstall": "node scripts/enforce-package-manager.cjs",
    "check:package-manager-policy": "node scripts/ci/check_package_manager_policy.mjs",
    "verify:frontend": "pnpm --filter ./apps/web run verify:frontend",
    "verify": "pnpm run check:default-scope && pnpm run verify:frontend",
    "check:test-skip-governance": "python scripts/ci/check_test_skip_governance.py --register config/ci/test_skip_register.yaml"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "packageManager": "pnpm@10.18.1",
  "pnpm": {
    "overrides": {
      "minimatch@>=9.0.0 <9.0.7": "9.0.9",
      "mermaid": ">=11.15.0 <12.0.0"
    }
  }
}
