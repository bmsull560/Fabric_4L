# IDE
.idea/
.vscode/
*.swp
*.swo
*~

# OS files
.DS_Store
Thumbs.db
._*
.Spotlight-V100
.Trashes
ehthumbs.db

# Environment variables
# Real .env files with secrets are never committed.
# Committed files: .env.example, .env.test, .env.staging, .env.production,
#                  .env.development, .env.production.example
.env
.env.dev
.env.local
.env.*.local

# Kubernetes secrets (use External Secrets Operator in production)
k8s/secrets.yml

# Logs
*.log
logs/

# Temporary files
tmp/
*.tmp
/tmp/

# Test artifacts
.pytest_cache/
.coverage
htmlcov/
.tox/
.mypy_cache/

# CI runtime artifacts
artifacts/

# Node.js (if used at root)
node_modules/
.pnpm-store/

# Python artifacts at root
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
.installed.cfg
*.egg
.venv/
venv/
env/
!packages/config/src/env/
!packages/config/src/env/**
ENV/

# Python artifacts in all subdirectories (ensures no __pycache__ anywhere)
**/__pycache__/
**/*.py[cod]
**/*$py.class

# Docker data volumes
postgres_data/
redis_data/
minio_data/
neo4j_data/

# SQLite databases
*.db
*.db-journal
*.sqlite
*.sqlite3

# Kubernetes secrets (never commit real credentials)
k8s/secrets.yml
k8s/secrets.yaml
k8s/*-secret.yml
k8s/*-secret.yaml

# Build artifacts
/build/
dist/
downloads/
eggs/
/lib/
/lib64/

# CI/Security evidence artifacts (generated during runs)
artifacts/zero-trust/
artifacts/backup-drill/
artifacts/performance/
.env.dev

# Additional cache directories (cleanup Phase 2)
.ruff_cache/
.vite/
test-results/

# Generated files directory (generated output should not be tracked)
generated/

# Root-level generated outputs (conservative cleanup)
valuepacks_output.txt
audit_violations.txt
audit-output/

# Windows shortcuts
*.lnk

# Certificate files
*.pem
*.key
*.crt
*.cer
