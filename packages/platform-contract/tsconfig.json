{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "baseUrl": ".",
    "paths": {
      "@fabric/platform-contract": ["./src/typescript/index.ts"],
      "@fabric/platform-contract/agent-result": ["./src/typescript/agent-result.ts"],
      "@fabric/platform-contract/routing": ["./src/typescript/routing.ts"],
      "@fabric/platform-contract/stores": ["./src/typescript/stores.ts"],
      "@fabric/platform-contract/agent-contracts": ["./src/typescript/agent-contracts/index.ts"]
    },
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true
  },
  "include": ["src/typescript/**/*.ts"],
  "exclude": ["src/typescript/negative/**"]
}
