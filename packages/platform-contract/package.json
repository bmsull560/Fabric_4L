{
  "name": "@fabric/platform-contract",
  "version": "1.0.0",
  "description": "Canonical platform contract for Fabric 4L",
  "type": "module",
  "exports": {
    ".": "./src/typescript/index.ts",
    "./agent-result": "./src/typescript/agent-result.ts",
    "./stores": "./src/typescript/stores.ts",
    "./routing": "./src/typescript/routing.ts",
    "./agent-contracts": "./src/typescript/agent-contracts/index.ts",
    "./generated": "./src/typescript/generated/index.ts"
  },
  "scripts": {
    "check": "pnpm run contract:test:ts",
    "typecheck": "pnpm run check",
    "test": "pnpm run contract:test",
    "contract:test:python": "python -m pytest src/python/canonical -v --tb=short",
    "contract:test:ts": "tsc -p tsconfig.json --noEmit",
    "contract:test:diagnostics": "node ./scripts/run-diagnostic-contract-tests.mjs",
    "contract:test": "pnpm run contract:test:python && pnpm run contract:test:ts && pnpm run contract:test:diagnostics",
    "generate:openapi-types": "node scripts/generate-openapi-types.mjs"
  },
  "devDependencies": {
    "typescript": "6.0.3"
  },
  "license": "MIT"
}
