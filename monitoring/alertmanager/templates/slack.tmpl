{{/*
  Slack notification templates for Alertmanager
  SECURITY NOTE: These templates render in Slack's mrkdwn format, not HTML.
  Slack mrkdwn does not support HTML tags, so XSS via template injection is not applicable.
  Variables are rendered as plain text in Slack's proprietary markup format.
  See: https://api.slack.com/reference/surfaces/formatting
*/}}
{{ define "slack.title" -}}
[{{ .Status | toUpper }}{{ if eq .Status "firing" }}:{{ .Alerts.Firing | len }}{{ end }}] {{ .GroupLabels.alertname }}
{{- end }}

{{ define "slack.text" -}}
{{ range .Alerts }}
*Severity:* {{ .Labels.severity | title }}
*Alert:* {{ .Annotations.summary }}
*Description:* {{ .Annotations.description }}
{{ if .Annotations.runbook_url }}*Runbook:* <{{ .Annotations.runbook_url }}|View Runbook>{{ end }}
{{ if .Annotations.escalation_url }}*Escalation:* <{{ .Annotations.escalation_url }}|Escalation Policy>{{ end }}
*Silence:* <{{ .GeneratorURL }}|Silence>
---
{{ end }}
{{- end }}
