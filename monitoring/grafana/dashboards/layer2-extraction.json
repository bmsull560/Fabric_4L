  "description": "Layer 2 - Entity Extraction: LLM-powered entity and value extraction metrics",
  "editable": true,
  "gnetId": null,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 0},
      "id": 1,
      "panels": [],
      "title": "API Health & Performance",
      "type": "row"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "mappings": [
            {"options": {"0": {"text": "DOWN"}}, "type": "value"},
            {"options": {"1": {"text": "UP"}}, "type": "value"}
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [{"color": "red", "value": 0}, {"color": "green", "value": 1}]
          }
        }
      },
      "gridPos": {"h": 4, "w": 4, "x": 0, "y": 1},
      "id": 2,
      "options": {"colorMode": "background"},
      "targets": [
        {"expr": "layer2_health_status{component=\"api\"} or vector(0)", "refId": "A"}
      ],
      "title": "API Health",
      "type": "stat"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"drawStyle": "line", "fillOpacity": 10},
          "unit": "reqps"
        }
      },
      "gridPos": {"h": 8, "w": 10, "x": 4, "y": 1},
      "id": 3,
      "targets": [
        {"expr": "rate(layer2_http_requests_total[5m])", "legendFormat": "{{method}} {{endpoint}}", "refId": "A"}
      ],
      "title": "Request Rate",
      "type": "timeseries"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"drawStyle": "line", "fillOpacity": 10},
          "unit": "percent"
        }
      },
      "gridPos": {"h": 8, "w": 10, "x": 14, "y": 1},
      "id": 4,
      "targets": [
        {"expr": "(rate(layer2_http_requests_total{status_code=~\"4..|5..\"}[5m]) / rate(layer2_http_requests_total[5m])) * 100 or vector(0)", "legendFormat": "Error %", "refId": "A"}
      ],
      "title": "Error Rate",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 9},
      "id": 5,
      "panels": [],
      "title": "Entity Extraction",
      "type": "row"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"drawStyle": "line", "fillOpacity": 10},
          "unit": "entities_per_sec"
        }
      },
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 10},
      "id": 6,
      "targets": [
        {"expr": "rate(value_fabric_entities_extracted_total[5m])", "legendFormat": "{{entity_type}}", "refId": "A"}
      ],
      "title": "Entities Extracted/sec",
      "type": "timeseries"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 0.85}, {"color": "red", "value": 0.95}]},
          "unit": "percentunit"
        }
      },
      "gridPos": {"h": 8, "w": 6, "x": 12, "y": 10},
      "id": 7,
      "options": {"colorMode": "value", "graphMode": "area"},
      "targets": [
        {"expr": "sum(rate(value_fabric_entities_extracted_total{confidence=\"high\"}[5m])) / sum(rate(value_fabric_entities_extracted_total[5m])) or vector(0)", "refId": "A"}
      ],
      "title": "High Confidence Rate",
      "type": "stat"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"drawStyle": "line", "fillOpacity": 10},
          "unit": "s"
        }
      },
      "gridPos": {"h": 8, "w": 6, "x": 18, "y": 10},
      "id": 8,
      "targets": [
        {"expr": "histogram_quantile(0.95, sum(rate(value_fabric_extraction_duration_seconds_bucket[5m])) by (le))", "legendFormat": "p95", "refId": "A"}
      ],
      "title": "Extraction Latency",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 18},
      "id": 9,
      "panels": [],
      "title": "LLM Usage & Costs",
      "type": "row"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"drawStyle": "line", "fillOpacity": 10},
          "unit": "short"
        }
      },
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 19},
      "id": 10,
      "targets": [
        {"expr": "rate(value_fabric_llm_tokens_total[5m])", "legendFormat": "{{token_type}}", "refId": "A"}
      ],
      "title": "LLM Tokens/sec",
      "type": "timeseries"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"drawStyle": "line", "fillOpacity": 10},
          "unit": "currencyUSD"
        }
      },
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 19},
      "id": 11,
      "targets": [
        {"expr": "rate(value_fabric_llm_cost_usd_total[5m]) * 3600", "legendFormat": "$/hour", "refId": "A"}
      ],
      "title": "LLM Cost ($/hour)",
      "type": "timeseries"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 36,
  "style": "dark",
  "tags": ["layer2", "extraction", "llm"],
  "time": {"from": "now-6h", "to": "now"},
  "timezone": "browser",
  "title": "Layer 2 - Entity Extraction",
  "uid": "layer2-extraction",
  "version": 1
}
