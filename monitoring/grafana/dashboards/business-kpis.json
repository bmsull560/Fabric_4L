      "id": 1,
      "panels": [],
      "title": "Formula & Value Evaluation",
      "type": "row"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"drawStyle": "line", "fillOpacity": 10},
          "unit": "eval_per_min"
        }
      },
      "gridPos": {"h": 8, "w": 8, "x": 0, "y": 1},
      "id": 2,
      "options": {"legend": {"displayMode": "table", "placement": "right"}},
      "targets": [
        {"expr": "rate(value_fabric_formula_evaluations_total[5m]) * 60", "legendFormat": "{{formula_type}} - {{status}}", "refId": "A"}
      ],
      "title": "Formula Evaluations/min",
      "type": "timeseries"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [{"color": "red", "value": null}, {"color": "yellow", "value": 0.9}, {"color": "green", "value": 0.98}]},
          "unit": "percentunit"
        }
      },
      "gridPos": {"h": 8, "w": 8, "x": 8, "y": 1},
      "id": 3,
      "options": {"colorMode": "value", "graphMode": "area"},
      "targets": [
        {"expr": "sum(rate(value_fabric_formula_evaluations_total{status=\"success\"}[1h])) / sum(rate(value_fabric_formula_evaluations_total[1h])) or vector(0)", "refId": "A"}
      ],
      "title": "Formula Success Rate (1h)",
      "type": "stat"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"drawStyle": "line", "fillOpacity": 10},
          "unit": "ms"
        }
      },
      "gridPos": {"h": 8, "w": 8, "x": 16, "y": 1},
      "id": 4,
      "options": {"legend": {"displayMode": "table", "placement": "right"}},
      "targets": [
        {"expr": "histogram_quantile(0.95, sum(rate(value_fabric_formula_evaluation_duration_seconds_bucket[5m])) by (le)) * 1000", "legendFormat": "p95", "refId": "A"}
