      "title": "Error Rates",
      "type": "row"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line"
          },
          "unit": "percent"
        }
      },
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 15
      },
      "id": 9,
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "right"
        }
      },
      "targets": [
        {
          "expr": "(rate(layer1_http_requests_total{status_code=~\"4..|5..\"}[5m]) / rate(layer1_http_requests_total[5m])) * 100 or vector(0)",
          "legendFormat": "L1 Error %",
          "refId": "A"
        },
        {
          "expr": "(rate(layer2_http_requests_total{status_code=~\"4..|5..\"}[5m]) / rate(layer2_http_requests_total[5m])) * 100 or vector(0)",
          "legendFormat": "L2 Error %",
          "refId": "B"
        },
        {
          "expr": "(rate(value_fabric_http_requests_total{status_code=~\"4..|5..\"}[5m]) / rate(value_fabric_http_requests_total[5m])) * 100 or vector(0)",
          "legendFormat": "L3 Error %",
          "refId": "C"
        },
        {
          "expr": "(rate(layer4_http_requests_total{status_code=~\"4..|5..\"}[5m]) / rate(layer4_http_requests_total[5m])) * 100 or vector(0)",
          "legendFormat": "L4 Error %",
          "refId": "D"
        },
        {
          "expr": "(rate(layer5_http_requests_total{status_code=~\"4..|5..\"}[5m]) / rate(layer5_http_requests_total[5m])) * 100 or vector(0)",
          "legendFormat": "L5 Ground Truth",
          "refId": "E"
        },
        {
          "expr": "(sum(rate(layer6_requests_total{status_class=~\"4xx|5xx\"}[5m])) / sum(rate(layer6_requests_total[5m]))) * 100 or vector(0)",
          "legendFormat": "L6 Benchmarks",
          "refId": "F"
        }
      ],
      "title": "Error Rate % (4xx + 5xx)",
      "type": "timeseries"
    },
