          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(layer1_http_request_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "L1 p95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(layer1_http_request_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "L1 p99",
          "refId": "C"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(value_fabric_http_request_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "L3 p95",
          "refId": "D"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(layer5_http_request_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "L5 p95",
          "refId": "E"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(layer6_request_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "L6 p95",
          "refId": "F"
        }
      ],
