        "h": 8,
        "w": 24,
        "x": 0,
        "y": 6
      },
      "id": 7,
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "showLegend": true
        }
      },
      "pluginVersion": "10.0.0",
      "targets": [
        {
          "expr": "rate(layer1_http_requests_total[5m])",
          "legendFormat": "L1 - {{endpoint}}",
          "refId": "A"
        },
        {
          "expr": "rate(layer2_http_requests_total[5m])",
          "legendFormat": "L2 - {{endpoint}}",
          "refId": "B"
        },
        {
          "expr": "rate(value_fabric_http_requests_total[5m])",
          "legendFormat": "L3 - {{endpoint}}",
          "refId": "C"
        },
        {
          "expr": "rate(layer4_http_requests_total[5m])",
          "legendFormat": "L4 - {{endpoint}}",
          "refId": "D"
        },
        {
          "expr": "rate(layer5_http_requests_total[5m])",
          "legendFormat": "L5 Ground Truth",
          "refId": "E"
        },
        {
          "expr": "sum(rate(layer6_requests_total[5m]))",
          "legendFormat": "L6 Benchmarks",
          "refId": "F"
        }
      ],
      "title": "Requests Per Second (5m rate)",
      "type": "timeseries"
    },
