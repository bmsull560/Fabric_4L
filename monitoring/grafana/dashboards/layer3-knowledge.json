{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": "-- Grafana --",
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "Layer 3 - Knowledge Graph: Entity relationships, graph queries, and semantic search metrics",
  "editable": true,
  "gnetId": null,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 0},
      "id": 1,
      "panels": [],
      "title": "API Health & Performance",
      "type": "row"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "mappings": [
            {"options": {"0": {"text": "DOWN"}}, "type": "value"},
            {"options": {"1": {"text": "UP"}}, "type": "value"}
          ],
          "thresholds": {"mode": "absolute", "steps": [{"color": "red", "value": 0}, {"color": "green", "value": 1}]}
        }
      },
      "gridPos": {"h": 4, "w": 4, "x": 0, "y": 1},
      "id": 2,
      "options": {"colorMode": "background"},
      "targets": [
        {"expr": "value_fabric_health_status{component=\"api\"} or vector(0)", "refId": "A"}
      ],
      "title": "API Health",
      "type": "stat"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"drawStyle": "line", "fillOpacity": 10},
          "unit": "reqps"
        }
      },
      "gridPos": {"h": 8, "w": 10, "x": 4, "y": 1},
      "id": 3,
      "targets": [
        {"expr": "rate(value_fabric_http_requests_total[5m])", "legendFormat": "{{method}} {{endpoint}}", "refId": "A"}
      ],
      "title": "Request Rate",
      "type": "timeseries"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"drawStyle": "line", "fillOpacity": 10},
          "unit": "percent"
        }
      },
      "gridPos": {"h": 8, "w": 10, "x": 14, "y": 1},
      "id": 4,
      "targets": [
        {"expr": "(rate(value_fabric_http_requests_total{status_code=~\"4..|5..\"}[5m]) / rate(value_fabric_http_requests_total[5m])) * 100 or vector(0)", "legendFormat": "Error %", "refId": "A"}
      ],
      "title": "Error Rate",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 9},
      "id": 5,
      "panels": [],
      "title": "Knowledge Graph",
      "type": "row"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"drawStyle": "line", "fillOpacity": 10},
          "unit": "short"
        }
      },
      "gridPos": {"h": 8, "w": 8, "x": 0, "y": 10},
      "id": 6,
      "targets": [
        {"expr": "value_fabric_graph_entities_total", "legendFormat": "Entities", "refId": "A"},
        {"expr": "value_fabric_graph_relationships_total", "legendFormat": "Relationships", "refId": "B"}
      ],
      "title": "Graph Size",
      "type": "timeseries"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"drawStyle": "line", "fillOpacity": 10},
          "unit": "short"
        }
      },
      "gridPos": {"h": 8, "w": 8, "x": 8, "y": 10},
      "id": 7,
      "targets": [
        {"expr": "rate(value_fabric_graph_queries_total[5m])", "legendFormat": "{{query_type}}", "refId": "A"}
      ],
      "title": "Graph Queries/sec",
      "type": "timeseries"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"drawStyle": "line", "fillOpacity": 10},
          "unit": "s"
        }
      },
      "gridPos": {"h": 8, "w": 8, "x": 16, "y": 10},
      "id": 8,
      "targets": [
        {"expr": "histogram_quantile(0.95, sum(rate(value_fabric_graph_query_duration_seconds_bucket[5m])) by (le))", "legendFormat": "p95", "refId": "A"}
      ],
      "title": "Query Latency",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 18},
      "id": 9,
      "panels": [],
      "title": "Semantic Search",
      "type": "row"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"drawStyle": "line", "fillOpacity": 10},
          "unit": "reqps"
        }
      },
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 19},
      "id": 10,
      "targets": [
        {"expr": "rate(value_fabric_semantic_search_requests_total[5m])", "legendFormat": "Searches/sec", "refId": "A"}
      ],
      "title": "Semantic Search Rate",
      "type": "timeseries"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [{"color": "red", "value": null}, {"color": "yellow", "value": 0.7}, {"color": "green", "value": 0.85}]},
          "unit": "percentunit"
        }
      },
      "gridPos": {"h": 8, "w": 6, "x": 12, "y": 19},
      "id": 11,
      "options": {"colorMode": "value", "graphMode": "area"},
      "targets": [
        {"expr": "avg(value_fabric_search_result_relevance_score) or vector(0)", "refId": "A"}
      ],
      "title": "Avg Relevance Score",
      "type": "stat"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"drawStyle": "line", "fillOpacity": 10},
          "unit": "ms"
        }
      },
      "gridPos": {"h": 8, "w": 6, "x": 18, "y": 19},
      "id": 12,
      "targets": [
        {"expr": "histogram_quantile(0.95, sum(rate(value_fabric_semantic_search_duration_seconds_bucket[5m])) by (le)) * 1000", "legendFormat": "p95", "refId": "A"}
      ],
      "title": "Search Latency (ms)",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 27},
      "id": 13,
      "panels": [],
      "title": "Value Trees",
      "type": "row"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"drawStyle": "line", "fillOpacity": 10},
          "unit": "short"
        }
      },
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 28},
      "id": 14,
      "targets": [
        {"expr": "value_fabric_value_trees_total", "legendFormat": "Total Trees", "refId": "A"},
        {"expr": "value_fabric_value_nodes_total", "legendFormat": "Total Nodes", "refId": "B"}
      ],
      "title": "Value Tree Metrics",
      "type": "timeseries"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"drawStyle": "line", "fillOpacity": 10},
          "unit": "reqps"
        }
      },
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 28},
      "id": 15,
      "targets": [
        {"expr": "rate(value_fabric_formula_evaluations_total[5m])", "legendFormat": "Evaluations/sec", "refId": "A"}
      ],
      "title": "Formula Evaluations",
      "type": "timeseries"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 36,
  "style": "dark",
  "tags": ["layer3", "knowledge", "graph"],
  "time": {"from": "now-6h", "to": "now"},
