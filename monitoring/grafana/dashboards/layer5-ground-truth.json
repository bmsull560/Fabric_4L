  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 0},
      "id": 1,
      "panels": [],
      "title": "API Health & Performance",
      "type": "row"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "mappings": [
            {"options": {"0": {"text": "DOWN"}}, "type": "value"},
            {"options": {"1": {"text": "UP"}}, "type": "value"}
          ],
          "thresholds": {"mode": "absolute", "steps": [{"color": "red", "value": 0}, {"color": "green", "value": 1}]}
        }
      },
      "gridPos": {"h": 4, "w": 4, "x": 0, "y": 1},
      "id": 2,
      "options": {"colorMode": "background"},
      "targets": [
        {"expr": "layer5_health_status{component=\"api\"} or vector(0)", "refId": "A"}
      ],
      "title": "API Health",
      "type": "stat"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"drawStyle": "line", "fillOpacity": 10},
          "unit": "reqps"
        }
      },
      "gridPos": {"h": 8, "w": 10, "x": 4, "y": 1},
      "id": 3,
      "targets": [
        {"expr": "rate(layer5_http_requests_total[5m])", "legendFormat": "{{method}} {{endpoint}}", "refId": "A"}
      ],
      "title": "Request Rate",
      "type": "timeseries"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"drawStyle": "line", "fillOpacity": 10},
          "unit": "percent"
        }
      },
      "gridPos": {"h": 8, "w": 10, "x": 14, "y": 1},
      "id": 4,
      "targets": [
        {"expr": "(rate(layer5_http_requests_total{status_code=~\"4..|5..\"}[5m]) / rate(layer5_http_requests_total[5m])) * 100 or vector(0)", "legendFormat": "Error %", "refId": "A"}
      ],
      "title": "Error Rate",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 9},
      "id": 5,
      "panels": [],
      "title": "Evaluation Framework",
      "type": "row"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"drawStyle": "line", "fillOpacity": 10},
          "unit": "tests_per_sec"
        }
      },
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 10},
      "id": 6,
      "targets": [
        {"expr": "rate(value_fabric_evaluations_total[5m])", "legendFormat": "{{test_type}} - {{status}}", "refId": "A"}
      ],
      "title": "Evaluations/sec",
      "type": "timeseries"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [{"color": "red", "value": null}, {"color": "yellow", "value": 0.85}, {"color": "green", "value": 0.95}]},
          "unit": "percentunit"
        }
      },
      "gridPos": {"h": 8, "w": 6, "x": 12, "y": 10},
      "id": 7,
      "options": {"colorMode": "value", "graphMode": "area"},
      "targets": [
        {"expr": "sum(rate(value_fabric_evaluations_total{status=\"pass\"}[5m])) / sum(rate(value_fabric_evaluations_total[5m])) or vector(0)", "refId": "A"}
      ],
      "title": "Pass Rate",
      "type": "stat"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"drawStyle": "line", "fillOpacity": 10},
          "unit": "s"
        }
      },
      "gridPos": {"h": 8, "w": 6, "x": 18, "y": 10},
      "id": 8,
      "targets": [
        {"expr": "histogram_quantile(0.95, sum(rate(value_fabric_evaluation_duration_seconds_bucket[5m])) by (le))", "legendFormat": "p95", "refId": "A"}
      ],
      "title": "Evaluation Latency",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 18},
      "id": 9,
      "panels": [],
      "title": "Test Coverage & Quality",
