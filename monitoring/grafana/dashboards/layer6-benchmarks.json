  "description": "Layer 6 - Benchmarks: Performance testing, load testing, and regression metrics",
  "editable": true,
  "gnetId": null,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 0},
      "id": 1,
      "panels": [],
      "title": "API Health & Performance",
      "type": "row"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "mappings": [
            {"options": {"0": {"text": "DOWN"}}, "type": "value"},
            {"options": {"1": {"text": "UP"}}, "type": "value"}
          ],
          "thresholds": {"mode": "absolute", "steps": [{"color": "red", "value": 0}, {"color": "green", "value": 1}]}
        }
      },
      "gridPos": {"h": 4, "w": 4, "x": 0, "y": 1},
      "id": 2,
      "options": {"colorMode": "background"},
      "targets": [
        {"expr": "layer6_health_status{component=\"api\"} or vector(0)", "refId": "A"}
      ],
      "title": "API Health",
      "type": "stat"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"drawStyle": "line", "fillOpacity": 10},
          "unit": "reqps"
        }
      },
      "gridPos": {"h": 8, "w": 10, "x": 4, "y": 1},
      "id": 3,
      "targets": [
        {"expr": "rate(layer6_http_requests_total[5m])", "legendFormat": "{{method}} {{endpoint}}", "refId": "A"}
      ],
      "title": "Request Rate",
      "type": "timeseries"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"drawStyle": "line", "fillOpacity": 10},
          "unit": "percent"
        }
      },
      "gridPos": {"h": 8, "w": 10, "x": 14, "y": 1},
      "id": 4,
      "targets": [
        {"expr": "(rate(layer6_http_requests_total{status_code=~\"4..|5..\"}[5m]) / rate(layer6_http_requests_total[5m])) * 100 or vector(0)", "legendFormat": "Error %", "refId": "A"}
      ],
      "title": "Error Rate",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 9},
      "id": 5,
      "panels": [],
      "title": "Benchmark Execution",
      "type": "row"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"drawStyle": "line", "fillOpacity": 10},
          "unit": "tests_per_sec"
        }
      },
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 10},
      "id": 6,
      "targets": [
        {"expr": "rate(value_fabric_benchmark_runs_total[5m])", "legendFormat": "{{benchmark_type}} - {{status}}", "refId": "A"}
      ],
      "title": "Benchmark Runs/sec",
      "type": "timeseries"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [{"color": "red", "value": null}, {"color": "yellow", "value": 0.8}, {"color": "green", "value": 0.95}]},
          "unit": "percentunit"
        }
      },
      "gridPos": {"h": 8, "w": 6, "x": 12, "y": 10},
      "id": 7,
      "options": {"colorMode": "value", "graphMode": "area"},
      "targets": [
        {"expr": "sum(rate(value_fabric_benchmark_runs_total{status=\"pass\"}[5m])) / sum(rate(value_fabric_benchmark_runs_total[5m])) or vector(0)", "refId": "A"}
      ],
      "title": "Benchmark Pass Rate",
      "type": "stat"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"drawStyle": "line", "fillOpacity": 10},
          "unit": "s"
        }
      },
      "gridPos": {"h": 8, "w": 6, "x": 18, "y": 10},
      "id": 8,
      "targets": [
        {"expr": "histogram_quantile(0.95, sum(rate(value_fabric_benchmark_duration_seconds_bucket[5m])) by (le))", "legendFormat": "p95", "refId": "A"}
      ],
      "title": "Benchmark Duration",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 18},
      "id": 9,
      "panels": [],
      "title": "Load Testing",
      "type": "row"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"drawStyle": "line", "fillOpacity": 10},
          "unit": "reqps"
        }
      },
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 19},
      "id": 10,
      "targets": [
        {"expr": "rate(value_fabric_load_test_requests_total[5m])", "legendFormat": "{{layer}}", "refId": "A"}
      ],
      "title": "Load Test RPS",
      "type": "timeseries"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"drawStyle": "line", "fillOpacity": 10},
          "unit": "ms"
        }
      },
      "gridPos": {"h": 8, "w": 6, "x": 12, "y": 19},
      "id": 11,
      "targets": [
        {"expr": "histogram_quantile(0.95, sum(rate(value_fabric_load_test_latency_seconds_bucket[5m])) by (le)) * 1000", "legendFormat": "p95", "refId": "A"}
      ],
      "title": "Load Test Latency",
      "type": "timeseries"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [{"color": "red", "value": null}, {"color": "yellow", "value": 1000}, {"color": "green", "value": 10000}]},
          "unit": "short"
        }
      },
      "gridPos": {"h": 8, "w": 6, "x": 18, "y": 19},
      "id": 12,
      "options": {"colorMode": "value", "graphMode": "area"},
      "targets": [
        {"expr": "value_fabric_concurrent_users", "refId": "A"}
      ],
      "title": "Concurrent Users",
      "type": "stat"
    },
    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 27},
      "id": 13,
      "panels": [],
      "title": "Performance Regression",
      "type": "row"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"drawStyle": "line", "fillOpacity": 10},
          "unit": "percent"
        }
      },
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 28},
      "id": 14,
      "targets": [
        {"expr": "(value_fabric_benchmark_latency_current - value_fabric_benchmark_latency_baseline) / value_fabric_benchmark_latency_baseline * 100", "legendFormat": "{{benchmark}} Latency", "refId": "A"}
      ],
      "title": "Latency Regression %",
      "type": "timeseries"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"drawStyle": "line", "fillOpacity": 10},
          "unit": "percent"
        }
      },
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 28},
      "id": 15,
      "targets": [
        {"expr": "(value_fabric_benchmark_throughput_current - value_fabric_benchmark_throughput_baseline) / value_fabric_benchmark_throughput_baseline * 100", "legendFormat": "{{benchmark}} Throughput", "refId": "A"}
      ],
      "title": "Throughput Regression %",
      "type": "timeseries"
    }
  ],
