{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": "-- Grafana --",
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "Layer 4 - Agents: Workflow orchestration, agent runs, and skill execution metrics",
  "editable": true,
  "gnetId": null,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 0},
      "id": 1,
      "panels": [],
      "title": "API Health & Performance",
      "type": "row"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "mappings": [
            {"options": {"0": {"text": "DOWN"}}, "type": "value"},
            {"options": {"1": {"text": "UP"}}, "type": "value"}
          ],
          "thresholds": {"mode": "absolute", "steps": [{"color": "red", "value": 0}, {"color": "green", "value": 1}]}
        }
      },
      "gridPos": {"h": 4, "w": 4, "x": 0, "y": 1},
      "id": 2,
      "options": {"colorMode": "background"},
      "targets": [
        {"expr": "layer4_health_status{component=\"api\"} or vector(0)", "refId": "A"}
      ],
      "title": "API Health",
      "type": "stat"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"drawStyle": "line", "fillOpacity": 10},
          "unit": "reqps"
        }
      },
      "gridPos": {"h": 8, "w": 10, "x": 4, "y": 1},
      "id": 3,
      "targets": [
        {"expr": "rate(layer4_http_requests_total[5m])", "legendFormat": "{{method}} {{endpoint}}", "refId": "A"}
      ],
      "title": "Request Rate",
      "type": "timeseries"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"drawStyle": "line", "fillOpacity": 10},
          "unit": "percent"
        }
      },
      "gridPos": {"h": 8, "w": 10, "x": 14, "y": 1},
      "id": 4,
      "targets": [
        {"expr": "(rate(layer4_http_requests_total{status_code=~\"4..|5..\"}[5m]) / rate(layer4_http_requests_total[5m])) * 100 or vector(0)", "legendFormat": "Error %", "refId": "A"}
      ],
      "title": "Error Rate",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 9},
      "id": 5,
      "panels": [],
      "title": "Agent Workflows",
      "type": "row"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"drawStyle": "line", "fillOpacity": 10},
          "unit": "runs_per_sec"
        }
      },
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 10},
      "id": 6,
      "targets": [
        {"expr": "rate(value_fabric_agent_workflow_runs_total[5m])", "legendFormat": "{{workflow_type}} - {{status}}", "refId": "A"}
      ],
      "title": "Workflow Runs/sec",
      "type": "timeseries"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [{"color": "red", "value": null}, {"color": "yellow", "value": 0.8}, {"color": "green", "value": 0.95}]},
          "unit": "percentunit"
        }
      },
      "gridPos": {"h": 8, "w": 6, "x": 12, "y": 10},
      "id": 7,
      "options": {"colorMode": "value", "graphMode": "area"},
      "targets": [
        {"expr": "sum(rate(value_fabric_agent_workflow_runs_total{status=\"success\"}[5m])) / sum(rate(value_fabric_agent_workflow_runs_total[5m])) or vector(0)", "refId": "A"}
      ],
      "title": "Workflow Success Rate",
      "type": "stat"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"drawStyle": "line", "fillOpacity": 10},
          "unit": "s"
        }
      },
      "gridPos": {"h": 8, "w": 6, "x": 18, "y": 10},
      "id": 8,
      "targets": [
        {"expr": "histogram_quantile(0.95, sum(rate(value_fabric_workflow_duration_seconds_bucket[5m])) by (le))", "legendFormat": "p95", "refId": "A"}
      ],
      "title": "Workflow Duration",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 18},
      "id": 9,
      "panels": [],
      "title": "Skill Execution",
      "type": "row"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"drawStyle": "line", "fillOpacity": 10},
          "unit": "exec_per_sec"
        }
      },
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 19},
      "id": 10,
      "targets": [
        {"expr": "rate(value_fabric_skill_executions_total[5m])", "legendFormat": "{{skill_name}}", "refId": "A"}
      ],
      "title": "Skill Executions/sec",
      "type": "timeseries"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [{"color": "red", "value": null}, {"color": "yellow", "value": 0.85}, {"color": "green", "value": 0.98}]},
          "unit": "percentunit"
        }
      },
      "gridPos": {"h": 8, "w": 6, "x": 12, "y": 19},
      "id": 11,
      "options": {"colorMode": "value", "graphMode": "area"},
      "targets": [
        {"expr": "sum(rate(value_fabric_skill_executions_total{status=\"success\"}[5m])) / sum(rate(value_fabric_skill_executions_total[5m])) or vector(0)", "refId": "A"}
      ],
      "title": "Skill Success Rate",
      "type": "stat"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"drawStyle": "line", "fillOpacity": 10},
          "unit": "ms"
        }
      },
      "gridPos": {"h": 8, "w": 6, "x": 18, "y": 19},
      "id": 12,
      "targets": [
        {"expr": "histogram_quantile(0.95, sum(rate(value_fabric_skill_duration_seconds_bucket[5m])) by (le)) * 1000", "legendFormat": "p95", "refId": "A"}
      ],
      "title": "Skill Latency (ms)",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 27},
      "id": 13,
      "panels": [],
      "title": "Queue & Concurrency",
      "type": "row"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"drawStyle": "line", "fillOpacity": 10},
          "unit": "short"
        }
      },
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 28},
      "id": 14,
      "targets": [
        {"expr": "value_fabric_workflow_queue_depth", "legendFormat": "Pending Workflows", "refId": "A"},
        {"expr": "value_fabric_active_workflows", "legendFormat": "Active", "refId": "B"}
      ],
      "title": "Workflow Queue Depth",
      "type": "timeseries"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"drawStyle": "line", "fillOpacity": 10},
          "unit": "short"
        }
      },
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 28},
      "id": 15,
      "targets": [
        {"expr": "value_fabric_agent_concurrency_current", "legendFormat": "Active Agents", "refId": "A"},
        {"expr": "value_fabric_agent_concurrency_max", "legendFormat": "Max Concurrency", "refId": "B"}
      ],
      "title": "Agent Concurrency",
      "type": "timeseries"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 36,
  "style": "dark",
  "tags": ["layer4", "agents", "workflows"],
  "time": {"from": "now-6h", "to": "now"},
  "timezone": "browser",
  "title": "Layer 4 - Agent Workflows",
