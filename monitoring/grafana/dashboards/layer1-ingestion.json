          "unit": "percent"
        }
      },
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 28},
      "id": 13,
      "options": {"legend": {"displayMode": "table", "placement": "right"}},
      "targets": [
        {"expr": "rate(process_cpu_seconds_total{job=\"layer1-ingestion\"}[5m]) * 100", "legendFormat": "CPU %", "refId": "A"}
      ],
      "title": "CPU Usage",
      "type": "timeseries"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
