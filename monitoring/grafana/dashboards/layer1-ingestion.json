  "description": "Layer 1 - Ingestion Pipeline: Document crawling, processing, and storage metrics",
  "editable": true,
  "gnetId": null,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 0},
      "id": 1,
      "panels": [],
      "title": "API Health & Performance",
      "type": "row"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "mappings": [
            {"options": {"0": {"text": "DOWN"}}, "type": "value"},
            {"options": {"1": {"text": "UP"}}, "type": "value"}
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "red", "value": 0},
              {"color": "green", "value": 1}
            ]
          },
          "unit": "none"
        }
      },
      "gridPos": {"h": 4, "w": 4, "x": 0, "y": 1},
      "id": 2,
      "options": {"colorMode": "background", "graphMode": "none", "orientation": "auto"},
      "targets": [
        {"expr": "layer1_health_status{component=\"api\"} or vector(0)", "refId": "A"}
      ],
      "title": "API Health",
      "type": "stat"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"drawStyle": "line", "fillOpacity": 10, "lineWidth": 2},
          "unit": "reqps"
        }
      },
      "gridPos": {"h": 8, "w": 10, "x": 4, "y": 1},
      "id": 3,
      "options": {"legend": {"displayMode": "table", "placement": "right"}},
      "targets": [
        {"expr": "rate(layer1_http_requests_total[5m])", "legendFormat": "{{method}} {{endpoint}}", "refId": "A"}
      ],
      "title": "Request Rate",
      "type": "timeseries"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"drawStyle": "line", "fillOpacity": 10},
          "unit": "percent"
        }
      },
      "gridPos": {"h": 8, "w": 10, "x": 14, "y": 1},
      "id": 4,
      "options": {"legend": {"displayMode": "table", "placement": "right"}},
      "targets": [
        {"expr": "(rate(layer1_http_requests_total{status_code=~\"4..|5..\"}[5m]) / rate(layer1_http_requests_total[5m])) * 100 or vector(0)", "legendFormat": "Error %", "refId": "A"}
      ],
      "title": "Error Rate",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 9},
      "id": 5,
      "panels": [],
      "title": "Ingestion Pipeline Metrics",
      "type": "row"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"drawStyle": "line", "fillOpacity": 10},
          "unit": "docs_per_sec"
        }
      },
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 10},
      "id": 6,
      "options": {"legend": {"displayMode": "table", "placement": "right"}},
      "targets": [
        {"expr": "rate(value_fabric_ingestion_operations_total[5m])", "legendFormat": "{{source_type}} - {{status}}", "refId": "A"}
      ],
      "title": "Documents Ingested/sec",
      "type": "timeseries"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "mappings": [],
          "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 95}, {"color": "red", "value": 99}]},
          "unit": "percent"
        }
      },
      "gridPos": {"h": 8, "w": 6, "x": 12, "y": 10},
      "id": 7,
      "options": {"colorMode": "value", "graphMode": "area"},
      "targets": [
        {"expr": "(sum(rate(value_fabric_ingestion_operations_total{status=\"success\"}[5m])) / sum(rate(value_fabric_ingestion_operations_total[5m]))) * 100 or vector(0)", "refId": "A"}
      ],
      "title": "Ingestion Success Rate",
      "type": "stat"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"drawStyle": "line", "fillOpacity": 10},
          "unit": "bytes"
        }
      },
      "gridPos": {"h": 8, "w": 6, "x": 18, "y": 10},
      "id": 8,
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}},
      "targets": [
        {"expr": "rate(value_fabric_ingestion_bytes_total[5m])", "legendFormat": "Bytes/sec", "refId": "A"}
      ],
      "title": "Ingestion Throughput",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 18},
      "id": 9,
      "panels": [],
      "title": "Crawler & Web Scraping",
      "type": "row"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"drawStyle": "line", "fillOpacity": 10},
          "unit": "short"
        }
      },
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 19},
      "id": 10,
      "options": {"legend": {"displayMode": "table", "placement": "right"}},
      "targets": [
        {"expr": "rate(value_fabric_crawler_pages_fetched_total[5m])", "legendFormat": "Pages/min", "refId": "A"},
        {"expr": "rate(value_fabric_crawler_links_discovered_total[5m])", "legendFormat": "Links/min", "refId": "B"}
      ],
      "title": "Crawler Activity",
      "type": "timeseries"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"drawStyle": "line", "fillOpacity": 10},
          "unit": "s"
        }
      },
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 19},
      "id": 11,
      "options": {"legend": {"displayMode": "table", "placement": "right"}},
      "targets": [
        {"expr": "histogram_quantile(0.95, sum(rate(value_fabric_crawler_page_fetch_duration_seconds_bucket[5m])) by (le))", "legendFormat": "p95", "refId": "A"},
        {"expr": "histogram_quantile(0.99, sum(rate(value_fabric_crawler_page_fetch_duration_seconds_bucket[5m])) by (le))", "legendFormat": "p99", "refId": "B"}
      ],
      "title": "Page Fetch Latency",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 27},
