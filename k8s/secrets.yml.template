# =============================================================================
# Kubernetes Secrets Template for Local Development
# =============================================================================
# WARNING: This is a template for local development only.
# For production, use External Secrets Operator with Vault.
#
# Usage:
#   cp k8s/secrets.yml.template k8s/secrets.yml
#   # Edit k8s/secrets.yml with your actual secrets (never commit!)
#   kubectl apply -f k8s/secrets.yml
# =============================================================================

apiVersion: v1
kind: Secret
metadata:
  name: postgres-secret
  namespace: value-fabric
  labels:
    value-fabric.io/environment: dev
  annotations:
    value-fabric.io/warning: "For local development only. Do not use in production."
type: Opaque
stringData:
  password: "REPLACE_WITH_SECURE_PASSWORD"
---
apiVersion: v1
kind: Secret
metadata:
  name: neo4j-secret
  namespace: value-fabric
  labels:
    value-fabric.io/environment: dev
  annotations:
    value-fabric.io/warning: "For local development only. Do not use in production."
type: Opaque
stringData:
  auth: "neo4j/REPLACE_WITH_SECURE_PASSWORD"
---
# Layer 4 primary LLM provider (Together.ai).
# Used by: k8s/layer4-agents.yml (TOGETHER_API_KEY)
apiVersion: v1
kind: Secret
metadata:
  name: llm-provider-secret
  namespace: value-fabric
  labels:
    value-fabric.io/environment: dev
  annotations:
    value-fabric.io/warning: "For local development only. Do not use in production."
type: Opaque
stringData:
  api-key: "REPLACE_WITH_TOGETHER_API_KEY"
---
# OpenAI API key — retained for layers that still use OpenAI directly.
# Layer 4 uses Together.ai (llm-provider-secret) as its primary provider.
apiVersion: v1
kind: Secret
metadata:
  name: openai-secret
  namespace: value-fabric
  labels:
    value-fabric.io/environment: dev
  annotations:
    value-fabric.io/warning: "For local development only. Do not use in production."
type: Opaque
stringData:
  api-key: "REPLACE_WITH_OPENAI_API_KEY"
---
apiVersion: v1
kind: Secret
metadata:
  name: jwt-secret
  namespace: value-fabric
  labels:
    value-fabric.io/environment: dev
  annotations:
    value-fabric.io/warning: "For local development only. Do not use in production."
type: Opaque
stringData:
  secret: "REPLACE_WITH_MINIMUM_32_CHARACTER_JWT_SECRET"
---
apiVersion: v1
kind: Secret
metadata:
  name: layer1-db-credentials
  namespace: value-fabric
  labels:
    value-fabric.io/environment: dev
  annotations:
    value-fabric.io/warning: "For local development only. Do not use in production."
type: Opaque
stringData:
  DATABASE_URL: "postgresql://REPLACE_USER:REPLACE_PASSWORD@postgres:5432/ingestion"
  REDIS_URL: "redis://:REPLACE_PASSWORD@redis:6379/0"
---
apiVersion: v1
kind: Secret
metadata:
  name: service-auth-secret
  namespace: value-fabric
  labels:
    value-fabric.io/environment: dev
  annotations:
    value-fabric.io/warning: "For local development only. Do not use in production."
type: Opaque
stringData:
  SERVICE_AUTH_SECRET: "REPLACE_WITH_32_CHAR_SERVICE_AUTH_SECRET"
---
apiVersion: v1
kind: Secret
metadata:
  name: anthropic-secret
  namespace: value-fabric
  labels:
    value-fabric.io/environment: dev
  annotations:
    value-fabric.io/warning: "For local development only. Do not use in production."
type: Opaque
stringData:
  api-key: "REPLACE_WITH_ANTHROPIC_API_KEY"
---
# PgBouncer authentication credentials.
# Used by: k8s/base/pgbouncer.yml (PGPASSWORD, userlist.txt volume)
apiVersion: v1
kind: Secret
metadata:
  name: pgbouncer-auth
  namespace: value-fabric
  labels:
    value-fabric.io/environment: dev
  annotations:
    value-fabric.io/warning: "For local development only. Do not use in production."
type: Opaque
stringData:
  pgbouncer-health-password: "REPLACE_WITH_PGBOUNCER_HEALTH_PASSWORD"
  userlist.txt: |
    "pgbouncer_health" "REPLACE_WITH_PGBOUNCER_HEALTH_PASSWORD"
